---
import { getCart, addItem } from '../lib/merklisteStore';
import Icon from './Icon.astro';

const { product } = Astro.props;

if (!product) {
  throw new Error('WishlistButton requires a product prop');
}

const cart = getCart();
const isInCart = cart.items.some(item => item.slug === product.slug);
const itemInCart = cart.items.find(item => item.slug === product.slug);
const quantity = itemInCart ? itemInCart.quantity : 0;
---
<button 
  class="wishlist-btn flex items-center gap-2 px-4 py-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl text-[var(--color-text)] hover:bg-[var(--color-bg)] hover:text-[var(--color-accent)] transition-all duration-200 active:scale-95"
  data-wishlist-slug={product.slug}
  id={`wishlist-btn-${product.slug}`}
  aria-pressed={isInCart ? "true" : "false"}
>
{isInCart && (
     <>
       <Icon name="check" class="w-4 h-4" />
       <span>Gemerkt ({quantity})</span>
     </>
   )}
    {!isInCart && (
      <>
        <Icon name="heart" class="w-5 h-5" />
        <span>Merken</span>
      </>
    )}
</button>

<script>
  import { addItem, getCart } from '../lib/merklisteStore';

  // Scope to all wishlist buttons (one per page) but attach only once per button
  function initButtons() {
    document.querySelectorAll('button.wishlist-btn[data-wishlist-slug]').forEach(button => {
      const slug = button.dataset.wishlistSlug;
      if (!slug) return;

      button.addEventListener('click', () => {
        addItem(slug);

        const wishlistBtn = document.querySelector(`button[data-wishlist-slug="${slug}"]`);
        const cart = getCart();
        const items = cart.items || [];
        const item = items.find(i => i.slug === slug);
        const qty = item ? item.quantity : 0;

        if (wishlistBtn) {
          if (qty > 0) {
            wishlistBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>Gemerkt (${qty})</span>
            `;
            wishlistBtn.setAttribute('aria-pressed', 'true');
          } else {
            wishlistBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
              <span>Merken</span>
            `;
            wishlistBtn.setAttribute('aria-pressed', 'false');
          }
        }

        const badge = document.querySelector('.merkliste-badge');
        if (badge) {
          const totalItems = cart.items.reduce((sum, i) => sum + i.quantity, 0);
          badge.textContent = totalItems;
          if (totalItems === 0) {
            badge.classList.add('hidden');
          } else {
            badge.classList.remove('hidden');
          }
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initButtons);
  } else {
    initButtons();
  }
</script>
