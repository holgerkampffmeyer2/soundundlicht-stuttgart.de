---
interface Props {
  items: string[];
  title?: string;
}

const { items, title = "Im Vermietungspaket enthalten" } = Astro.props;
---

<section class="section-padding bg-[var(--color-surface)]">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Ausstattung</span>
      <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">{title}</h2>
    </div>

    <div class="includes-grid">
      {items.map((item, index) => (
        <div class="include-item" style={`animation-delay: ${index * 0.1}s`}>
          <div class="include-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <span class="include-text">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .include-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-bg);
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
    animation: fadeInUp 0.5s ease forwards;
    opacity: 0;
  }

  .include-item:hover {
    border-color: var(--color-secondary);
    transform: translateX(5px);
  }

  .include-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-accent));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .include-text {
    color: var(--color-text);
    font-weight: 500;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
