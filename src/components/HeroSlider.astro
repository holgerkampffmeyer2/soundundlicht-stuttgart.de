---
import { Picture } from 'astro:assets';

interface Button {
  text: string;
  href: string;
  class?: string;
}

interface Slide {
  title: string;
  titleTag?: "h1" | "h2";
  description: string;
  category?: string;
  categoryColor?: string;
  buttons: Button[];
  backgroundImage?: string;
  gradient?: string;
  ptClass?: string;
}

interface Props {
  slides: Slide[];
  interval?: number;
  id?: string;
}

const { slides, interval = 5000, id = "hero" } = Astro.props;

const defaultSlides = [
  { path: '/img/slider/slide1.webp', meta: await import('/src/assets/slider/slide1.jpg').then(m => m.default) },
  { path: '/img/slider/slide2.webp', meta: await import('/src/assets/slider/slide2.jpg').then(m => m.default) },
  { path: '/img/slider/slide3.webp', meta: await import('/src/assets/slider/slide3.jpg').then(m => m.default) },
  { path: '/img/slider/slide4.webp', meta: await import('/src/assets/slider/slide4.jpg').then(m => m.default) },
];

function getSlideImage(path: string) {
  return defaultSlides.find(s => s.path === path)?.meta;
}
---

  <section id={id} class="hero-slider" data-interval={interval}>
  {slides.map((slide, index) => {
    const imgSrc = slide.backgroundImage || `/img/slider/slide${index + 1}.webp`;
    const imgMeta = getSlideImage(imgSrc);
    const isLcp = index === 0;
    return (
    <div class={`slide slide-${index + 1} ${index === 0 ? "active" : ""}`} data-slide={index} tabindex={index === 0 ? undefined : "-1"} aria-hidden={index === 0 ? undefined : "true"}>
{imgMeta ? (
         <Picture
           src={imgMeta}
           formats={['avif', 'webp', 'jpeg']}
           alt=""
           class="hero-bg-img"
           width={1920}
           height={1080}
           loading={isLcp ? "eager" : "lazy"}
           fetchpriority={isLcp ? "high" : "low"}
         />
       ) : (
         <img
           src={imgSrc}
           alt=""
           class="hero-bg-img"
           width="1920"
           height="1080"
           fetchpriority={isLcp ? "high" : "low"}
           loading={isLcp ? "eager" : "lazy"}
         />
       )}
      <div class="slide-overlay" style={slide.gradient ? `background: ${slide.gradient}` : undefined}></div>
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class={`max-w-5xl ${slide.ptClass || ""}`}>
            {slide.category && (
              <span
                class="text-lg tracking-widest uppercase"
                style={slide.categoryColor ? `color: ${slide.categoryColor}` : undefined}
              >
                {slide.category}
              </span>
            )}
            {slide.titleTag === "h2" ? (
              <h2 class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text">
                {slide.title}
              </h2>
            ) : (
              <h1 class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text">
                {slide.title}
              </h1>
            )}
            <p class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-4xl">
              {slide.description}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              {slide.buttons.map((btn) => (
                <a href={btn.href} class={btn.class || "btn-primary"}>{btn.text}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
    );
  })}

  <button class="slider-nav prev" id="slider-prev" aria-label="Vorheriger Slide">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button class="slider-nav next" id="slider-next" aria-label="Nächster Slide">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <div class="slider-dots">
    {slides.map((_, index) => (
      <button class={`slider-dot ${index === 0 ? "active" : ""}`} data-dot={index} aria-label={`Slide ${index + 1}`}></button>
    ))}
  </div>
  <slot />
  <script>
  (function() {
    const section = document.querySelector(".hero-slider") as HTMLElement | null;
    if (!section) return;
    const intervalAttr = section.dataset.interval;
    const interval = intervalAttr ? parseInt(intervalAttr) : 5000;
    
    const slides = section.querySelectorAll(".slide");
    const dots = section.querySelectorAll(".slider-dot");
    const prevBtn = section.querySelector("#slider-prev");
    const nextBtn = section.querySelector("#slider-next");

    if (!slides.length) return;

    let currentSlide = 0;
    let slideInterval: ReturnType<typeof setInterval> | null = null;

    function showSlide(index: number) {
      slides.forEach((slide, i) => {
        slide.classList.toggle("active", i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("active", i === index);
      });
      currentSlide = index;
    }

    function nextSlide() {
      showSlide((currentSlide + 1) % slides.length);
    }

    function prevSlide() {
      showSlide((currentSlide - 1 + slides.length) % slides.length);
    }

    function startSlider() {
      stopSlider();
      slideInterval = setInterval(nextSlide, interval);
    }

    function stopSlider() {
      if (slideInterval) clearInterval(slideInterval);
    }

    prevBtn?.addEventListener("click", () => {
      prevSlide();
      startSlider();
    });

    nextBtn?.addEventListener("click", () => {
      nextSlide();
      startSlider();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        showSlide(i);
        startSlider();
      });
    });

    startSlider();
  })();
</script>
</section>
