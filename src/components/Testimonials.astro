---
import StarIcon from "./icons/StarIcon.astro";
import GoogleIcon from "./icons/GoogleIcon.astro";
import googleReviewsData from '../data/google-reviews.json';

const { id } = Astro.props;

const ITEMS_PER_PAGE = 3;
const allReviews = googleReviewsData.reviews || [];
const totalPages = Math.ceil(allReviews.length / ITEMS_PER_PAGE);
---

<section id={id} class="section-padding bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Rezensionen</span>
      <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Was sagen meine Kunden?</h2>
    </div>
    
    {allReviews.length === 0 ? (
      <p class="text-center text-[var(--color-text-muted)]">Noch keine Rezensionen vorhanden. Kommen bald wieder!</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="reviewsGrid">
        {allReviews.map((review, index) => (
          <div class="review-card bg-[var(--color-bg)] rounded-xl p-6 border border-[var(--color-border)] hover:border-[var(--color-secondary)] review-card-hover transition-all duration-300" data-page={Math.floor(index / ITEMS_PER_PAGE) + 1}>
            <div class="flex gap-1 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <StarIcon class={`w-5 h-5 ${i < review.rating ? 'star-active' : 'text-gray-400'}`} />
              ))}
              <GoogleIcon class="w-4 h-4 ml-2 text-gray-400" />
            </div>
            <p class="text-[var(--color-text-muted)] mb-4">{review.text}</p>
            <div class="border-t border-[var(--color-border)] pt-4">
              <h3 class="font-bold">{review.author_name}</h3>
              <span class="text-sm text-[var(--color-text-muted)]">{review.relative_time_description}</span>
            </div>
          </div>
        ))}
      </div>
    )}

    {totalPages > 1 && ( 
      <nav class="flex justify-center mt-12" aria-label="Pagination">
        <ul class="flex items-center -space-x-px h-10 text-base">
          <li>
            <button 
              id="prevPage"
              class="flex items-center justify-center px-4 h-10 ms-0 leading-tight border border-gray-300 rounded-s-lg text-[var(--color-text)] bg-[var(--color-bg)] hover:bg-[var(--color-surface)] hover:text-[var(--color-secondary)] disabled:opacity-50 disabled:cursor-not-allowed"
              disabled
            >
              <span class="sr-only">Previous</span>
              <svg class="w-3 h-3" aria-hidden="true" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 1 1 5l4 4"/>
              </svg>
            </button>
          </li>
          {[...Array(totalPages)].map((_, i) => {
            const pageNumber = i + 1;
            return (
              <li>
                <button
                  class="page-btn flex items-center justify-center px-4 h-10 leading-tight border border-gray-300 text-[var(--color-text)] bg-[var(--color-bg)] hover:bg-[var(--color-surface)] hover:text-[var(--color-secondary)]"
                  data-page={pageNumber}
                >
                  {pageNumber}
                </button>
              </li>
            );
          })}
          <li>
            <button 
              id="nextPage"
              class="flex items-center justify-center px-4 h-10 leading-tight border border-gray-300 rounded-e-lg text-[var(--color-text)] bg-[var(--color-bg)] hover:bg-[var(--color-surface)] hover:text-[var(--color-secondary)]"
            >
              <span class="sr-only">Next</span>
              <svg class="w-3 h-3" aria-hidden="true" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 9l4-4-4-4"/>
              </svg>
            </button>
          </li>
        </ul>
      </nav>
    )}
  </div>
</section>

<script is:inline type="module" define:vars={{ totalPages, ITEMS_PER_PAGE }}>
  (() => {
    let currentPage = 1;
    const cards = document.querySelectorAll('.review-card');
    const pageBtns = document.querySelectorAll('.page-btn');
    const prevBtn = document.getElementById('prevPage');
    const nextBtn = document.getElementById('nextPage');

    function showPage(page) {
      cards.forEach((card, index) => {
        const cardPage = Math.floor(index / ITEMS_PER_PAGE) + 1;
        card.style.display = cardPage === page ? 'block' : 'none';
      });

      pageBtns.forEach(btn => {
        const btnPage = parseInt(btn.dataset.page);
        if (btnPage === page) {
          btn.classList.add('bg-[var(--color-secondary)]', 'text-white', 'border-[var(--color-secondary)]');
          btn.classList.remove('text-[var(--color-text)]', 'bg-[var(--color-bg)]', 'border-gray-300');
        } else {
          btn.classList.remove('bg-[var(--color-secondary)]', 'text-white', 'border-[var(--color-secondary)]');
          btn.classList.add('text-[var(--color-text)]', 'bg-[var(--color-bg)]', 'border-gray-300');
        }
      });

      prevBtn.disabled = page === 1;
      nextBtn.disabled = page === totalPages;
      currentPage = page;
    }

    pageBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        showPage(parseInt(btn.dataset.page));
      });
    });

    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) showPage(currentPage - 1);
    });

    nextBtn.addEventListener('click', () => {
      if (currentPage < totalPages) showPage(currentPage + 1);
    });

    showPage(1);
  })();
</script>
