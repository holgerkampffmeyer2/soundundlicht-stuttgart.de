---
import VolumeUpIcon from "./icons/VolumeUpIcon.astro";
import LightBulbIcon from "./icons/LightBulbIcon.astro";
import PackageIcon from "./icons/PackageIcon.astro";
import ShieldCheckIcon from "./icons/ShieldCheckIcon.astro";
import CheckIcon from "./icons/CheckIcon.astro";
---
<div class="mt-16">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-secondary)] transition-all duration-300">
      <div class="icon-circle icon-circle-secondary mb-4">
        <VolumeUpIcon class="w-6 h-6" />
      </div>
      <h3 class="font-bold text-lg mb-2">PA-Anlagen & Partyboxen</h3>
      <p class="text-[var(--color-text-muted)] text-sm">
        Kraftvoller Sound für Partys, Hochzeiten und Vereinsfeiern. Professionelle Musikanlagen und Partyboxen.
      </p>
    </div>
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-secondary)] transition-all duration-300">
      <div class="icon-circle icon-circle-primary mb-4">
        <LightBulbIcon class="w-6 h-6" />
      </div>
      <h3 class="font-bold text-lg mb-2">Lichttechnik</h3>
      <p class="text-[var(--color-text-muted)] text-sm">
        LED-Lichteffekte, Partylichtanlagen, Nebelmaschinen und komplette Lichtanlagen für die perfekte Stimmung.
      </p>
    </div>
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-secondary)] transition-all duration-300">
      <div class="icon-circle icon-circle-accent mb-4">
        <PackageIcon class="w-6 h-6" />
      </div>
      <h3 class="font-bold text-lg mb-2">Komplettpakete</h3>
      <p class="text-[var(--color-text-muted)] text-sm">
        Vermietung von Kombi-Angeboten aus Sound & Licht. Zuverlässig, hochwertig und mit persönlicher Beratung.
      </p>
    </div>
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-secondary)] transition-all duration-300">
      <div class="icon-circle icon-circle-secondary mb-4">
        <ShieldCheckIcon class="w-6 h-6" />
      </div>
      <h3 class="font-bold text-lg mb-2">Warum bei mir mieten?</h3>
      <ul class="text-[var(--color-text-muted)] text-sm space-y-2">
        <li class="flex items-center gap-2">
          <CheckIcon class="w-5 h-5 text-[var(--color-secondary)]" />
          Technik vor Abholung ansehen & ausprobieren – kein Überraschungspaket
        </li>
        <li class="flex items-center gap-2">
          <CheckIcon class="w-5 h-5 text-[var(--color-secondary)]" />
          Kein Lieferrisiko – Geräte sind garantiert da am Tag der Party
        </li>
        <li class="flex items-center gap-2">
          <CheckIcon class="w-5 h-5 text-[var(--color-secondary)]" />
          Kurzfristig möglich: 1-3 Tage Vorlauf reichen oft
        </li>
        <li class="flex items-center gap-2">
          <CheckIcon class="w-5 h-5 text-[var(--color-secondary)]" />
          Persönliche Einweisung – Aufbau wird erklärt, nichts bleibt unklar
        </li>
      </ul>
    </div>
  </div>
</div>
