---
import { Picture } from 'astro:assets';
import logo from '@assets/logo/djhulk_logo.webp';
import Icon from "./Icon.astro";
import CartIcon from "./CartIcon.astro";

interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;

const vermietungItems = [
  { href: '/vermietung', label: 'Übersicht' },
  { href: '/vermietung/partypaket-stuttgart', label: 'Partypaket' },
  { href: '/vermietung/veranstaltungspaket-stuttgart', label: 'Veranstaltungspaket' },
  { href: '/vermietung/djpaket-fildern', label: 'DJ-Paket' },
  { href: '/vermietung/akku-party-paket', label: 'Akku-Party-Paket' },
  { href: '/vermietung/karaoke-paket', label: 'Karaoke-Paket' },
  { href: '/vermietung/ld-maui-28g3', label: 'LD Maui 28 G3' },
  { href: '/vermietung/jbl-partybox-300-320', label: 'JBL Partybox 300/320' },
  { href: '/vermietung/partylicht-moving-head', label: 'Partylicht & Moving Head' },
  { href: '/vermietung/led-bossfx-nebelmaschine', label: 'LED BossFX & Nebelmaschine' },
  { href: '/vermietung/kls-laser-bar', label: 'KLS Laser Bar' },
];

const isVermietungActive = currentPage.startsWith('/vermietung');
const activeVermietungSlug = isVermietungActive ? currentPage.replace('/vermietung', '') || '/' : null;
---

<nav data-pagefind-ignore class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3">
        <Picture src={logo} formats={['avif', 'webp', 'jpeg']} alt="Sound und Licht Stuttgart Logo" width={48} height={48} loading="eager" class="h-12" />
        <span class="font-play text-xl font-bold hidden sm:block">Sound & Licht Stuttgart</span>
      </a>
      
      <!-- Desktop Menu -->
      <div class="desktop-menu hidden md:flex items-center space-x-6">
        <a href="/" class:list={["nav-link", { active: currentPage === '/' || currentPage === 'home' }]}>Home</a>
        
        <!-- Vermietung Dropdown -->
        <div class="relative group">
          <a 
            href="/vermietung" 
            class:list={["nav-link flex items-center gap-1", { active: isVermietungActive }]}
          >
            Vermietung
            <Icon name="chevron-down" class="h-4 w-4" />
          </a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-56 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {vermietungItems.map(item => (
              <a 
                href={item.href} 
                class:list={[
                  "block px-4 py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] hover:bg-[var(--color-bg)] first:rounded-t-lg last:rounded-b-lg",
                  { "text-[var(--color-secondary)] bg-[var(--color-bg)]": activeVermietungSlug === item.href.replace('/vermietung', '') }
                ]}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
        <a href="/#services" class="nav-link">Services</a>
        <a href="/#pakete" class="nav-link">Pakete</a>
        <a href="/#ablauf" class="nav-link">Ablauf</a>
        <a href="/#bewertungen" class="nav-link">Bewertungen</a>
<a href="/#kontakt" class="nav-link">Kontakt</a>
         <CartIcon class="ml-4" />
       </div>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden text-[var(--color-text)] p-2" aria-label="Toggle mobile menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-surface)] border-t border-[var(--color-border)]">
    <div class="px-4 py-4 space-y-3">
      <a href="/" class:list={["block nav-link py-2", { active: currentPage === '/' || currentPage === 'home' }]}>Home</a>
      <a href="/vermietung" class:list={["block nav-link py-2", { active: isVermietungActive }]}>Vermietung</a>
      <a href="/#services" class="block nav-link py-2">Services</a>
      <a href="/#pakete" class="block nav-link py-2">Pakete</a>
      <a href="/#ablauf" class="block nav-link py-2">Ablauf</a>
      <a href="/#bewertungen" class="block nav-link py-2">Bewertungen</a>
      <a href="/#kontakt" class="block nav-link py-2">Kontakt</a>
      <div class="pt-2 border-t border-[var(--color-border)]">
        <CartIcon class="block" />
      </div>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const navLinks = document.querySelectorAll('.nav-link');
  const sections = document.querySelectorAll('section[id]') as NodeListOf<HTMLElement>;
  
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
    });
  });
  
  let ticking = false;
  function updateActiveLink() {
    const scrollPos = window.scrollY + 100;
    let currentSection: string | null = null;
    
    sections.forEach(section => {
      const sectionEl = section as HTMLElement;
      const sectionTop = sectionEl.offsetTop;
      const sectionHeight = sectionEl.offsetHeight;
      const sectionId = section.getAttribute('id');
      
      if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
        currentSection = sectionId;
      }
    });

    navLinks.forEach(link => {
      link.classList.remove('active');
      const href = link.getAttribute('href') || '';
      
      if (href === '/' && currentSection === 'home') {
        link.classList.add('active');
      }
      
      if (href === '/vermietung/' && window.location.pathname.startsWith('/vermietung')) {
        link.classList.add('active');
      }
      
      const hash = href.split('#')[1];
      if (hash && currentSection === hash) {
        link.classList.add('active');
      }
    });
    ticking = false;
  }
  
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => updateActiveLink());
      ticking = true;
    }
  }, { passive: true });
  updateActiveLink();
</script>
