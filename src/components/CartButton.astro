---
import { getCart, addItem } from '../lib/cartStore';
import Icon from './Icon.astro';

const { product } = Astro.props;

if (!product) {
  throw new Error('CartButton requires a product prop');
}

const cart = getCart();
const isInCart = cart.items.some(item => item.slug === product.slug);
const itemInCart = cart.items.find(item => item.slug === product.slug);
const quantity = itemInCart ? itemInCart.quantity : 0;
---
<button 
  class="cart-button flex items-center gap-2 px-4 py-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl text-[var(--color-text)] hover:bg-[var(--color-bg)] hover:text-[var(--color-accent)] transition-all duration-200 active:scale-95"
  data-cart-slug={product.slug}
  id={`cart-button-${product.slug}`}
>
{isInCart && (
     <>
       <Icon name="check" class="w-4 h-4" />
       <span>Im Warenkorb ({quantity})</span>
     </>
   )}
    {!isInCart && (
      <>
        <Icon name="cart" class="w-5 h-5" />
        <span>Zum Warenkorb hinzufügen</span>
      </>
    )}
</button>

<script>
  import { addItem } from '../lib/cartStore';
  
  document.querySelectorAll('button.cart-button[data-cart-slug]').forEach(button => {
    const slug = button.dataset.cartSlug;
    if (!slug) return;
    
    button.addEventListener('click', () => {
      addItem(slug);
      
      // Update UI optimistically
      const cartButton = document.querySelector(`button[data-cart-slug="${slug}"]`);
      const cart = JSON.parse(localStorage.getItem('sls_cart') || '{}');
      const items = cart.items || [];
      const item = items.find(i => i.slug === slug);
      const qty = item ? item.quantity : 0;

      if (cartButton) {
        if (qty > 0) {
          cartButton.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span>Im Warenkorb (${qty})</span>
          `;
        } else {
          cartButton.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
            <span>Zum Warenkorb hinzufügen</span>
          `;
        }
      }
      
      // Update cart badge in header
      const cartBadge = document.querySelector('.cart-badge');
      if (cartBadge) {
        const totalItems = items.reduce((sum, i) => sum + i.quantity, 0);
        cartBadge.textContent = totalItems;
        cartBadge.classList.toggle('hidden', totalItems === 0);
      }
    });
  });
</script>

