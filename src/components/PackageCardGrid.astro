---
interface Props {
  pakete: any[];
}

const { pakete } = Astro.props;

function getWebpUrl(src: string): string {
  // Convert JPG/PNG to WebP, keep WebP as-is
  return src.replace(/\.(jpe?g|png)$/i, '.webp');
}

function getThumbUrl(src: string): string {
  // Generate thumbnail path: filename-thumb.webp
  return src.replace(/\.[^.]+$/, '-thumb.webp');
}

import Icon from './Icon.astro';
---
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
   {pakete.map((item, index) => (
     <div class="equipment-card" style={`animation-delay: ${index * 0.1}s`}>
        <div class="relative">
          <picture>
            <source srcset={`${getThumbUrl(item.image)} 480w, ${getWebpUrl(item.image)} 960w`} type="image/webp" />
            <img src={item.image} alt={item.title} width="400" height="256" loading="lazy" decoding="async" class="rounded-xl w-full h-64 object-cover mb-4 bg-[var(--color-surface)]" />
          </picture>
          <span class="plug-badge">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Inkl. Kabel & Einweisung
          </span>
        </div>
        <span class="price-badge">{item.price}</span>
        <h3 class="text-xl font-bold mt-2 mb-3">{item.title}</h3>
       <p class="text-[var(--color-text-muted)] text-sm mb-4">{item.description}</p>
       <ul class="text-[var(--color-text-muted)] text-sm space-y-1">
         {item.features.map(feature => (
           <li class="flex items-center gap-2">
             <span class="text-[var(--color-secondary)]">•</span> {feature}
           </li>
         ))}
       </ul>
    <div class="flex flex-col gap-2">
           <button data-action="add-to-cart" data-slug={item.slug} class="btn-primary w-full">
              <span class="grid grid-cols-[auto_1fr] gap-3 items-start text-left">
                <Icon name="cart" class="w-6 h-6 mt-0.5 shrink-0" />
                <span class="text-xs leading-snug">Zum Warenkorb hinzufügen</span>
              </span>
            </button>
           {item.detailPage && (
             <a href={item.detailPage} class="btn-secondary w-full text-center block">Mehr Infos</a>
           )}
         </div>
       </div>
     ))}
  </div>

<script>
  import { addItem } from '../lib/cartStore';

  document.addEventListener('click', (e) => {
    const target = e.target.closest('[data-action="add-to-cart"]');
    if (!target) return;
    const slug = target.dataset.slug;
    if (!slug) return;

    addItem(slug);

    const button = document.querySelector(`button[data-slug="${slug}"][data-action="add-to-cart"]`);
    if (button) {
      button.innerHTML = '<span class="grid grid-cols-[auto_1fr] gap-3 items-start text-left"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-xs leading-snug">Im Warenkorb (1)</span></span>';
    }

    const cartBadge = document.querySelector('.cart-badge');
    if (cartBadge) {
      const items = JSON.parse(localStorage.getItem('sls_cart') || '{}').items || [];
      const totalItems = items.reduce((sum, i) => sum + i.quantity, 0);
      cartBadge.textContent = totalItems;
      cartBadge.classList.toggle('hidden', totalItems === 0);
    }
  });
</script>