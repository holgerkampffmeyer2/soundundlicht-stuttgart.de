---
import Icon from './Icon.astro';

interface Props {
  threshold?: number;
  href?: string;
  productSlug?: string;
}

const { threshold = 15, href = "#kontakt", productSlug } = Astro.props;
---

<div class="sticky-merkliste sticky-merkliste-initial" data-threshold={threshold}>
  <div class="sticky-panel">
    {productSlug && (
      <button class="sticky-panel-btn" data-action="add-to-wishlist" data-product-slug={productSlug} aria-pressed="false">
        <Icon name="heart" class="w-4 h-4" />
        <span>Merken</span>
      </button>
    )}
    <a href={href} class="sticky-panel-btn" data-action="request-now">
      <Icon name="email" class="w-4 h-4" />
      <span>Jetzt anfragen</span>
    </a>
    <button class="sticky-panel-link relative" data-action="toggle-wishlist" aria-expanded="false">
      <Icon name="heart" class="w-5 h-5" />
      <span class="absolute -top-1.5 -right-1.5 flex h-3.5 min-w-3.5 items-center justify-center text-[9px] font-bold bg-[var(--color-accent)] text-white rounded-full merkliste-badge hidden">0</span>
      <span>Merkliste betrachten</span>
    </button>
  </div>
</div>

<script>
  import { addItem, getCart } from '../lib/merklisteStore';

  (function() {
    function updateBadge() {
      var badges = document.querySelectorAll('.sticky-merkliste .merkliste-badge');
      var cart = getCart();
      var items = cart.items || [];
      var count = 0;
      for (var i = 0; i < items.length; i++) { count += items[i].quantity; }
      for (var j = 0; j < badges.length; j++) {
        var badge = badges[j];
        badge.textContent = count;
        if (count > 0) {
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      }
    }

    var cta = document.querySelector('.sticky-merkliste');
    if (!cta) return;
    var threshold = parseInt(cta.dataset.threshold || '15');
    var ticking = false;

    function onScroll() {
      var scrollY = window.scrollY;
      var viewportH = window.innerHeight;
      var docH = document.documentElement.scrollHeight;
      var scrollPercent = (scrollY / (docH - viewportH)) * 100;
      cta.classList.toggle('visible', scrollPercent > threshold);
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(function() {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    });

    document.addEventListener('toggle-merkliste', updateBadge);
    document.addEventListener('merkliste-prefill', updateBadge);
    updateBadge();

    (function() {
      var addBtn = document.querySelector('[data-action="add-to-wishlist"][data-product-slug]');
      if (addBtn) {
        var slug = addBtn.dataset.productSlug;
        var cart = getCart();
        var items = cart.items || [];
        var inCart = false;
        for (var i = 0; i < items.length; i++) {
          if (items[i].slug === slug) { inCart = true; break; }
        }
        if (inCart) {
          addBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span>Gemerkt</span>';
          addBtn.setAttribute('aria-pressed', 'true');
        }
      }
    })();

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-action="add-to-wishlist"]');
      if (btn) {
        var slug = btn.dataset.productSlug;
        if (slug) {
          addItem(slug);
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span>Gemerkt</span>';
          btn.setAttribute('aria-pressed', 'true');
          document.dispatchEvent(new CustomEvent('merkliste-prefill'));
        }
        return;
      }

      btn = e.target.closest('[data-action="toggle-wishlist"]');
      if (btn) {
        document.dispatchEvent(new CustomEvent('toggle-merkliste'));
        return;
      }

      btn = e.target.closest('[data-action="request-now"]');
      if (btn) {
        var slug = btn.closest('[data-product-slug]') ? btn.closest('[data-product-slug]').dataset.productSlug : null;
        var panel = btn.closest('.sticky-panel');
        if (panel) {
          var addBtn = panel.querySelector('[data-action="add-to-wishlist"]');
          if (addBtn) {
            slug = addBtn.dataset.productSlug;
          }
        }
        if (slug) {
          addItem(slug);
          document.dispatchEvent(new CustomEvent('merkliste-prefill'));
        } else {
          document.dispatchEvent(new CustomEvent('merkliste-prefill'));
        }
      }
    });
  })();
</script>

<style>
  .sticky-merkliste {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    transform: translateY(calc(100% + 2rem));
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
  }

  .sticky-merkliste.visible {
    transform: translateY(0);
    opacity: 1;
  }

  .sticky-panel {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 0.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    min-width: 220px;
  }

  .sticky-panel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 9999px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-accent) 40%, transparent);
  }

  .sticky-panel-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 28px color-mix(in srgb, var(--color-accent) 60%, transparent);
  }

  .sticky-panel-btn:active {
    transform: scale(0.97);
  }

  .sticky-panel-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.5rem;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    border: none;
    cursor: pointer;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .sticky-panel-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .sticky-merkliste {
      bottom: 1rem;
      right: 1rem;
    }
  }
</style>
