---
import ChevronRightIcon from "./icons/ChevronRightIcon.astro";
const { faqs } = Astro.props;
---
<div class="mt-16">
  <h2 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
    Häufig gestellte Fragen
  </h2>
  {faqs.length === 0 ? (
    <p class="text-center text-[var(--color-text-muted)]">No FAQs found for this page.</p>
  ) : (
    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq: any) => (
        <details class="faq-details bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4 cursor-pointer">
          <summary class="font-bold cursor-pointer flex items-center gap-3 list-none relative">
            <span class="faq-icon shrink-0">
              <ChevronRightIcon class="w-3 h-3 transition-transform duration-200" />
            </span>
            {faq.question}
          </summary>
          <p class="text-[var(--color-text-muted)] mt-3 ml-9">
            {faq.answer}
          </p>
        </details>
      ))}
    </div>
  )}
  <style>
    .faq-details summary .faq-icon svg {
      transition: transform 0.2s ease-in-out;
    }
    .faq-details[open] summary .faq-icon svg {
      transform: rotate(90deg);
    }
  </style>
</div>
