---
import Icon from './Icon.astro';
import WishlistButton from './WishlistButton.astro';

interface Props {
  product: { slug: string; title: string };
  label?: string;
}

const { product, label = 'diesem Paket' } = Astro.props;
---
<section class="cta-section section-padding bg-[var(--color-surface)]">
  <div class="max-w-4xl mx-auto text-center px-4">
    <h2 class="font-play text-3xl md:text-4xl font-bold mb-2">Interessiert an {label}?</h2>
    <p class="text-[var(--color-text-muted)] mb-6">
      Stell uns eine Anfrage für {product.title} oder lass dich beraten.
    </p>
    <button id={`request-now-${product.slug}`} class="btn-primary max-w-sm mx-auto mb-6">
      <span class="flex items-center justify-center gap-2">
        <Icon name="email" class="w-5 h-5" />
        Jetzt anfragen
      </span>
    </button>
    <div class="flex flex-wrap gap-3 justify-center items-center mb-4">
      <WishlistButton product={product} class="btn-secondary" />
    </div>
    <a href="/vermietung" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] text-sm inline-flex items-center gap-1 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Zurück zur Übersicht
    </a>
  </div>
</section>

<!--
  Single delegated listener for all request-now-{slug} buttons across product pages.
  Replaces 10 identical per-page scripts. Re-runs every time the component is rendered,
  but the IIFE + already-flag pattern ensures idempotent registration.
-->
<script>
  (() => {
    const SCRIPT_ID = 'productcta-request-now-init';
    if ((window as unknown as Record<string, boolean>)[SCRIPT_ID]) return;
    (window as unknown as Record<string, boolean>)[SCRIPT_ID] = true;

    document.addEventListener('click', (e) => {
      const target = (e.target as Element)?.closest('[id^="request-now-"]');
      if (!target) return;
      const slug = target.id.replace(/^request-now-/, '');
      if (!slug) return;
      document.dispatchEvent(new CustomEvent('add-to-wishlist', { detail: { slug } }));
      document.dispatchEvent(new CustomEvent('toggle-merkliste'));
    });
  })();
</script>
