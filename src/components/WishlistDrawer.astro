---
import Icon from './Icon.astro';
---

<div id="merkliste-drawer" class="fixed inset-0 z-50 flex-col items-center justify-center hidden bg-[var(--overlay-scrim)]" role="dialog" aria-modal="true" aria-label="Merkliste">
  <div class="relative w-full max-w-xs mx-4 sm:max-w-md bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl shadow-lg p-6 max-h-[90vh] overflow-y-auto">
    <button id="merkliste-close" class="absolute top-2 right-2 p-2 rounded hover:bg-[var(--color-accent)/10] transition-colors" aria-label="Merkliste schließen">
      <Icon name="x" class="w-4 h-4" />
    </button>

    <h2 class="font-play text-2xl font-bold mb-4 text-center">Ihre Merkliste</h2>

    <div id="merkliste-contents">
      <p class="text-[var(--color-text-muted)] text-center">Ihre Merkliste ist leer.</p>
    </div>

    <div id="merkliste-footer" class="mt-6 pt-4 border-t border-[var(--color-border)] hidden">
      <button id="request-btn" class="w-full btn-primary">Jetzt anfragen</button>
    </div>
  </div>
</div>

<script>
  import { getCart, addItem, removeItem } from '../lib/merklisteStore';

  function getCatalog() {
    var script = document.getElementById('rental-catalog-data');
    if (!script) return {};
    try {
      var products = JSON.parse(script.textContent);
      var map = {};
      for (var i = 0; i < products.length; i++) {
        map[products[i].slug] = products[i];
      }
      return map;
    } catch (e) { return {}; }
  }

  function escapeHtml(s: string): string {
    if (!s) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function updateBadge(count: number): void {
    var badges = document.querySelectorAll('.merkliste-badge');
    for (var i = 0; i < badges.length; i++) {
      var badge = badges[i];
      badge.textContent = count;
      if (count > 0) {
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }
  }

  function renderMerkliste(): void {
    var container = document.getElementById('merkliste-contents');
    var footer = document.getElementById('merkliste-footer');
    if (!container) return;

    try {
      var data = getCart();
      var items = data.items || [];

      if (items.length === 0) {
        container.innerHTML = '<p class="text-[var(--color-text-muted)] text-center">Ihre Merkliste ist leer.</p>';
        if (footer) footer.classList.add('hidden');
        updateBadge(0);
        return;
      }

      var catalog = getCatalog();
      var html = '<div class="space-y-4">';

      for (var i = 0; i < items.length; i++) {
        var item = items[i];
        var product = catalog[item.slug];
        var title = escapeHtml(product ? product.title : item.slug);
        var image = product ? product.image : '';
        var priceStr = product ? product.price : '';

        var imgHtml = '';
        if (image) {
          var thumbWebp = image.replace(/\.(jpe?g|png)$/i, '-thumb.webp');
          imgHtml = '<picture class="shrink-0">' +
            '<source srcset="' + escapeHtml(thumbWebp) + '" type="image/webp" />' +
            '<img src="' + escapeHtml(image) + '" alt="' + title + '" width="60" height="60" class="rounded-xl object-cover" />' +
            '</picture>';
        }

        html += '<div class="merkliste-item flex items-start space-x-4">' +
          imgHtml +
          '<div class="flex-1 space-y-2">' +
          '<h3 class="font-play font-lg font-bold">' + title + '</h3>' +
          '<p class="text-[var(--color-text-muted)] text-sm">Preis: <span class="font-semibold">' + escapeHtml(priceStr) + '</span></p>' +
          '<div>' +
          '<button data-action="remove" data-slug="' + escapeHtml(item.slug) + '" class="text-[var(--color-accent)] hover:underline">Entfernen</button>' +
          '</div>' +
          '</div>' +
          '</div>';
      }

      html += '</div>';
      container.innerHTML = html;

      if (footer) {
        footer.classList.remove('hidden');
      }

      updateBadge(items.length);

      var cartInput = document.getElementById('merkliste-data');
      if (cartInput) {
        var vals = items.map(function(it) {
          var prod = catalog[it.slug];
          var t = prod ? prod.title : it.slug;
          var p = prod ? prod.price : '';
          return t + ' (' + p + ')';
        });
        cartInput.value = vals.join(', ');
      }
    } catch (e) {
      container.innerHTML = '<p class="text-[var(--color-text-muted)] text-center">Fehler beim Laden der Merkliste.</p>';
    }
  }

  function closeDrawer(): void {
    document.getElementById('merkliste-drawer')?.classList.remove('open');
  }

  function openDrawer(): void {
    var drawer = document.getElementById('merkliste-drawer');
    if (!drawer) return;
    drawer.classList.add('open');
    renderMerkliste();
    var closeBtn = document.getElementById('merkliste-close');
    if (closeBtn) setTimeout(function() { closeBtn.focus(); }, 50);
  }

  function toggleDrawer(): void {
    var drawer = document.getElementById('merkliste-drawer');
    if (!drawer) return;
    if (drawer.classList.contains('open')) {
      closeDrawer();
    } else {
      openDrawer();
    }
  }

  document.addEventListener('toggle-merkliste', function() {
    toggleDrawer();
    var toggleBtn = document.querySelector('[data-action="toggle-wishlist"]');
    if (toggleBtn) {
      var isOpen = document.getElementById('merkliste-drawer')?.classList.contains('open');
      toggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeDrawer();
  });

  document.getElementById('merkliste-close')?.addEventListener('click', closeDrawer);

  document.getElementById('merkliste-drawer')?.addEventListener('click', function(e) {
    if (e.target === this) closeDrawer();
  });

  document.addEventListener('click', function(e) {
    var target = e.target.closest('[data-action]') || e.target;
    var action = target.dataset.action;
    var slug = target.dataset.slug;
    if (!action || !slug) return;

    if (action === 'remove') {
      removeItem(slug);
      renderMerkliste();
    }
  });

  document.getElementById('request-btn')?.addEventListener('click', function() {
    var cartInput = document.getElementById('merkliste-data');
    if (cartInput) {
      var data = getCart();
      var items = data.items || [];
      if (items.length > 0) {
        var catalog = getCatalog();
        var vals = items.map(function(item) {
          var prod = catalog[item.slug];
          var title = prod ? prod.title : item.slug;
          var price = prod ? prod.price : '';
          return title + ' (' + price + ')';
        }).join(', ');
        cartInput.value = vals;
      }
    }
    document.dispatchEvent(new CustomEvent('merkliste-prefill'));
    closeDrawer();
    var contactSection = document.getElementById('kontakt');
    if (contactSection) {
      contactSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      window.location.href = '/vermietung#kontakt';
    }
  });
</script>

<style>
  #merkliste-drawer {
    @apply hidden;
    transition: opacity 0.2s ease;
  }
  #merkliste-drawer.open {
    @apply flex;
  }
  #merkliste-drawer > div {
    transform: scale(0.95);
    opacity: 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  #merkliste-drawer.open > div {
    transform: scale(1);
    opacity: 1;
  }
  #merkliste-drawer::before {
    content: '';
    position: fixed;
    inset: 0;
    background: var(--overlay-scrim);
    z-index: -1;
  }
</style>
