---
interface Props {
  threshold?: number;
  href?: string;
}

const { threshold = 30, href = "#kontakt" } = Astro.props;
---

<div class="sticky-cta sticky-cta-initial" data-threshold={threshold}>
  <a href={href} class="sticky-cta-btn">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
    </svg>
    <span>Jetzt anfragen</span>
  </a>
</div>

<script>
  (function() {
    const cta = document.querySelector('.sticky-cta');
    if (!cta) return;
    const threshold = parseInt(cta.dataset.threshold || '80');
    let ticking = false;

    function onScroll() {
      const scrollY = window.scrollY;
      const viewportH = window.innerHeight;
      const docH = document.documentElement.scrollHeight;
      const scrollPercent = (scrollY / (docH - viewportH)) * 100;
      const pastThreshold = scrollPercent > threshold;
      cta.classList.toggle('visible', pastThreshold);
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(function() {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    transform: translateY(calc(100% + 2rem));
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
  }

  .sticky-cta.visible {
    transform: translateY(0);
    opacity: 1;
  }

  .sticky-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 9999px;
    text-decoration: none;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: all 0.3s ease;
  }

  .sticky-cta-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 28px color-mix(in srgb, var(--color-accent) 60%, transparent);
  }

  @media (max-width: 640px) {
    .sticky-cta {
      bottom: 1rem;
      right: 1rem;
    }
    .sticky-cta-btn {
      padding: 0.65rem 1.25rem;
      font-size: 0.85rem;
    }
  }
</style>
