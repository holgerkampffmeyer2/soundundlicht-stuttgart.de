---
import { getItemCount } from '../lib/merklisteStore';
import Icon from './Icon.astro';

const count = getItemCount();
const badgeHidden = count === 0;
---
<button id="merkliste-toggle" class="relative flex items-center space-x-2 p-2 rounded hover:bg-[var(--color-accent)/10] hover:text-[var(--color-accent)] transition-colors" aria-label="Merkliste ({count})">
  <Icon name="heart" class="w-5 h-5" />
  <span class="ml-2">Merkliste</span>
  <span class:list={["absolute -top-1 -right-1 flex h-3 min-w-3 items-center justify-center text-[10px] font-bold bg-[var(--color-accent)] text-[var(--color-bg)] rounded-full merkliste-badge", badgeHidden ? "hidden" : ""]}>
    {count}
  </span>
</button>

<script>
  document.getElementById('merkliste-toggle')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('toggle-merkliste'));
  });
</script>

<style>
  #merkliste-toggle {
    @apply relative inline-flex;
  }
</style>
