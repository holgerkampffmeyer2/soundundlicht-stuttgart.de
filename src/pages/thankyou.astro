---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const productsBySlug = Object.fromEntries(allProducts.map(p => [p.slug, p.data]));
---
<Layout
  title="Anfrage versendet | Sound & Licht Stuttgart"
  description="Deine Anfrage wurde erfolgreich versendet. Ich melde mich innerhalb von 12 Stunden bei dir."
  noIndex={true}
>
  <Navbar />
  
  <section class="section-padding min-h-[70vh] flex items-center bg-[var(--color-bg)]">
    <div class="max-w-2xl mx-auto text-center animate-on-scroll">
      <div class="text-7xl mb-6">
        <Icon name="check" class="w-20 h-20 mx-auto text-[var(--color-accent)]" />
      </div>
      <h1 class="font-play text-4xl md:text-5xl font-bold mb-6">
        Anfrage versendet! ✅
      </h1>
      <p class="text-[var(--color-text-muted)] text-xl mb-4">
        Vielen Dank für deine Anfrage.
      </p>
      <p class="text-[var(--color-text-muted)] mb-10 max-w-lg mx-auto">
        Ich melde mich innerhalb von <strong class="text-[var(--color-text)]">12 Stunden</strong> bei dir mit einem individuellen Angebot. 
        <span class="text-[var(--color-accent)] font-medium">Bei dringenden Anfragen:</span> 
        <a href="tel:01711467491" class="text-[var(--color-accent)] font-semibold underline">0171 146 7491</a> 
        oder 
        <a href="mailto:holger.kampffmeyer+dj@gmail.com" class="text-[var(--color-accent)] font-semibold underline">per E‑Mail</a>.
      </p>
      
      <!-- Merkliste -->
      <div id="merkliste-summary" class="mt-6 text-left w-full max-w-xs mx-auto"></div>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung" class="btn-primary">
          Zurück zur Vermietung ↗
        </a>
        <a href="/" class="btn-secondary">
          Zur Startseite
        </a>
      </div>
      <div class="mt-12 bg-[var(--color-surface)] rounded-xl p-6 max-w-md mx-auto grid gap-4">
        <div class="flex items-start space-x-4">
          <Icon name="phone" class="h-6 w-6 text-[var(--color-accent)] flex-shrink-0" />
          <div>
            <h2 class="font-play font-bold mb-1 text-base">Telefon</h2>
            <p class="text-[var(--color-text-muted)]">
              <a href="tel:01711467491" class="text-[var(--color-accent)] font-semibold hover:underline">
                0171 146 7491
              </a>
            </p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <Icon name="email" class="h-6 w-6 text-[var(--color-accent)] flex-shrink-0" />
          <div>
            <h2 class="font-play font-bold mb-1 text-base">E‑Mail</h2>
            <p class="text-[var(--color-text-muted)]">
              <a href="mailto:holger.kampffmeyer+dj@gmail.com" class="text-[var(--color-accent)] font-semibold hover:underline">
                holger.kampffmeyer+dj@gmail.com
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
    </section>
  
  <Footer />
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const productScript = document.getElementById('rental-catalog-data');
      const productsBySlug = productScript ? JSON.parse(productScript.textContent) : {};
      
      const cartSummary = document.getElementById('merkliste-summary');
      if (!cartSummary) return;
      
      try {
        const cart = JSON.parse(localStorage.getItem('sls_merkliste') || '{}');
        const items = cart.items || [];
        if (items.length === 0) {
          cartSummary.innerHTML = '<p class="text-[var(--color-text-muted)]">Ihre Merkliste ist leer.</p>';
          return;
        }
        
        let rows = '';
        items.forEach(item => {
          const product = productsBySlug?.[item.slug];
          if (!product) {
            rows += `<div class="mb-4"><span class="font-semibold">${item.slug}</span> (Produkt nicht gefunden)</div>`;
            return;
          }
          rows += `
            <div class="flex items-start space-x-4 mb-4">
              <div class="flex-shrink-0">
                <img src="${product.image}" alt="${product.title}" width="50" height="50" class="rounded object-cover" onerror="this.src='https://via.placeholder.com/50?img=missing'">
              </div>
              <div class="flex-1 space-y-1">
                <div class="font-semibold">${product.title}</div>
                <div class="text-[var(--color-text-muted)] text-sm">Preis: ${product.price}</div>
              </div>
            </div>
          `;
        });
        
        cartSummary.innerHTML = `
          <h2 class="font-play font-bold mb-2 text-base">Ihre Merkliste</h2>
          <div class="space-y-4">${rows}</div>
          <div class="mt-4 pt-2 border-t border-[var(--color-border)]">
            <p class="text-[var(--color-text-muted)] text-sm">
              Bitte beachten Sie: Dies ist eine unverbindliche Anfrage. Die angegebenen Preise sind Richtwerte.
            </p>
            <button id="clear-merkliste" class="mt-2 btn-secondary w-full">Merkliste leeren</button>
          </div>
        `;
        
        const clearBtn = document.getElementById('clear-merkliste');
        if (clearBtn) {
          clearBtn.addEventListener('click', () => {
            localStorage.removeItem('sls_merkliste');
            location.reload();
          });
        }
      } catch (e) {
        console.error('Failed to render merkliste', e);
        cartSummary.innerHTML = '<p class="text-[var(--color-text-muted)]">Fehler beim Laden der Merkliste.</p>';
      }
    });
  </script>
</Layout>