---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
---

<Layout
  title="Anfrage versendet | Sound & Licht Stuttgart"
  description="Deine Anfrage wurde erfolgreich versendet. Ich melde mich innerhalb von 12 Stunden bei dir."
  noIndex={true}
>
  <Navbar />

  <section class="section-padding min-h-[70vh] flex items-center bg-[var(--color-bg)]">
    <div class="max-w-2xl mx-auto text-center animate-on-scroll">
      <div class="text-7xl mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 mx-auto text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h1 class="font-play text-4xl md:text-5xl font-bold mb-6">
        Anfrage versendet! ✅
      </h1>
      <p class="text-[var(--color-text-muted)] text-xl mb-4">
        Vielen Dank für deine Anfrage.
      </p>
      <p class="text-[var(--color-text-muted)] mb-10 max-w-lg mx-auto">
        Ich melde mich innerhalb von <strong class="text-[var(--color-text)]">12 Stunden</strong> bei dir mit einem individuellen Angebot. 
        <span class="text-[var(--color-accent)] font-medium">Bei dringenden Anfragen:</span> 
        <a href="tel:01711467491" class="text-[var(--color-accent)] font-semibold underline">0171 146 7491</a> 
        oder 
        <a href="mailto:holger.kampffmeyer+dj@gmail.com" class="text-[var(--color-accent)] font-semibold underline">per E‑Mail</a>.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung" class="btn-primary">
          Zurück zur Vermietung ↗
        </a>
        <a href="/" class="btn-secondary">
          Zur Startseite
        </a>
      </div>
      <div class="mt-12 bg-[var(--color-surface)] rounded-xl p-6 max-w-md mx-auto grid gap-4">
        <div class="flex items-start space-x-4">
          <Icon name="phone" class="h-6 w-6 text-[var(--color-accent)] flex-shrink-0" />
          <div>
            <h3 class="font-play font-bold mb-1">Telefon</h3>
            <p class="text-[var(--color-text-muted)]">
              <a href="tel:01711467491" class="text-[var(--color-accent)] font-semibold hover:underline">
                0171 146 7491
              </a>
            </p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <Icon name="email" class="h-6 w-6 text-[var(--color-accent)] flex-shrink-0" />
          <div>
            <h3 class="font-play font-bold mb-1">E‑Mail</h3>
            <p class="text-[var(--color-text-muted)]">
              <a href="mailto:holger.kampffmeyer+dj@gmail.com" class="text-[var(--color-accent)] font-semibold hover:underline">
                holger.kampffmeyer+dj@gmail.com
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
