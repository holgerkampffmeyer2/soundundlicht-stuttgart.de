---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CityHero from "../components/CityHero.astro";
import CityPackages from "../components/CityPackages.astro";
import CitySteps from "../components/CitySteps.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContactSection from "../components/ContactSection.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Tübingen" }
];

const cityFaqs = getFaqsForPage('index');

const cityJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung Tübingen",
  "areaServed": {
    "@type": "City",
    "name": "Tübingen"
  },
  "provider": {
    "@type": "LocalBusiness",
    "name": "Sound & Licht Stuttgart - Holger Kampffmeyer",
    "url": "https://soundundlicht-stuttgart.de"
  }
};
---

<Layout
  title="Veranstaltungstechnik mieten in Tübingen | Sound & Licht Stuttgart"
  description="PA-Anlagen, Partyboxen und Lichttechnik mieten in Tübingen. Komplettpakete für Parties, Hochzeiten und Uni-Events. Abholung in Leinfelden-Echterdingen, nur 25 km von Tübingen."
  image="/img/header.webp"
  jsonLd={cityJsonLd}
>
  <Navbar currentPage="city" />

  <Breadcrumb segments={breadcrumbSegments} />

  <CityHero
    image="/img/cities/tuebingen.webp"
    city="Tübingen"
    title="Veranstaltungstechnik mieten in Tübingen"
    description="Du planst eine Party, ein Studentenfest oder eine Hochzeit in Tübingen? Ich vermiete PA-Anlagen, Partyboxen und Lichttechnik für Veranstaltungen jeder Größe – ob auf dem Schlossberg, in der Altstadt oder im Vereinsheim."
    details="Von Tübingen aus bist du in ca. 30 Minuten über die B27 bei mir in Leinfelden-Echterdingen. Die Technik ist Plug & Play, ich erkläre dir alles vor Ort. Auch kurzfristige Anfragen sind möglich! Anders als bei Versandverleihern kannst du die Technik vor der Abholung in Funktion sehen und bekommst eine persönliche Einweisung – so weißt du genau, was dich erwartet."
  />

  <CityPackages />
  <CitySteps />

  <!-- FAQ -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={cityFaqs} />
    </div>
  </section>

  <ContactSection
    title="Technik mieten in Tübingen – einfach anfragen"
    description="Du kommst aus Tübingen und brauchst Technik für deine Veranstaltung? Schreib mir eine E-Mail mit deinem Wunschdatum und der gewünschten Ausrüstung. Die Abholung ist in Leinfelden-Echterdingen, Magellanstraße 4 – verkehrsgünstig an A8 / B27, nur ca. 25 km von Tübingen über die B27. Ich melde mich innerhalb von 12 Stunden bei dir!"
    distanceText="Nur ca. 25 km von Tübingen über die B27"
  />

  <Footer />
</Layout>
