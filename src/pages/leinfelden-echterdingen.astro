---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CityHero from "../components/CityHero.astro";
import CityPackages from "../components/CityPackages.astro";
import CitySteps from "../components/CitySteps.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContactSection from "../components/ContactSection.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Leinfelden-Echterdingen" }
];

const cityFaqs = getFaqsForPage('leinfelden-echterdingen');

const cityJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung Leinfelden-Echterdingen",
  "areaServed": {
    "@type": "City",
    "name": "Leinfelden-Echterdingen"
  },
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cityFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout
  title="Veranstaltungstechnik mieten in Leinfelden-Echterdingen | Sound & Licht Stuttgart"
  description="Partytechnik mieten in Leinfelden-Echterdingen: PA-Anlagen, Partyboxen und Lichttechnik direkt vor Ort zur Abholung. Komplettpakete für deine Feier – Magellanstraße 4."
  image="/img/header.webp"
  jsonLd={[cityJsonLd, faqJsonLd]}
>
  <Navbar currentPage="city" />

  <Breadcrumb segments={breadcrumbSegments} />

  <CityHero
    image="/img/cities/leinfelden-echterdingen.webp"
    city="Leinfelden-Echterdingen"
    title="Veranstaltungstechnik mieten in Leinfelden-Echterdingen"
    description="Du wohnst in Leinfelden-Echterdingen und brauchst Technik für deine Party? Perfekt – mein Standort ist in der Magellanstraße 4, direkt bei dir um die Ecke. PA-Anlagen, Partyboxen, Lichttechnik und Komplettpakete zur sofortigen Abholung."
    details="Als lokaler Anbieter in Leinfelden-Echterdingen kennst du mich vielleicht schon. Ich berate dich persönlich, zeige dir die Technik vor Ort und erkläre dir den Aufbau. Auch kurzfristige Anfragen sind möglich – einfach anrufen! Anders als bei Versandverleihern siehst du die Technik vor Abholung live in Funktion und bekommst eine Einweisung."
  />

  <CityPackages />
  <CitySteps />

  <!-- FAQ -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={cityFaqs} />
    </div>
  </section>

  <ContactSection
    title="Technik mieten in Leinfelden-Echterdingen"
    description="Du wohnst in Leinfelden-Echterdingen? Ruf einfach kurz an oder schreib mir eine E-Mail. Mein Standort: Magellanstraße 4, 70771 Leinfelden-Echterdingen – verkehrsgünstig an A8 / B27. Ich melde mich innerhalb von 12 Stunden bei dir!"
    distanceText="Direkt vor Ort – verkehrsgünstig an A8 / B27"
  />

  <Footer />
</Layout>
