---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQSection from '../components/FAQSection.astro';
import MietanfrageAblauf from '../components/vermietung/MietanfrageAblauf.astro';
import HeroSlider from "../components/HeroSlider.astro";
import { getCollection } from 'astro:content';
import { getFaqsForPage } from '../lib/faqUtils';
import { serviceArea, offerCatalogJsonLd } from '../data/jsonLd';
import PackageCardGrid from '../components/PackageCardGrid.astro';

const products = await getCollection('products');
const rentalItems = products.map(i => i.data);
const faqs = await getFaqsForPage('vermietung');

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung",
  "description": "Verleih von Musikanlagen, Partyboxen, Lichttechnik und DJ-Equipment im Großraum Stuttgart",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  },
  "areaServed": serviceArea
};

const komplettPakete = rentalItems.filter(i => i.category === 'Paket');
const soundEquipment = rentalItems.filter(i => i.category === 'Sound');
const lichtEquipment = rentalItems.filter(i => i.category === 'Licht');
---

<Layout 
  title="Vermietung - Sound und Licht Stuttgart - Partyboxen, Lichttechnik und DJ-Equipment mieten"
  description="Verleih von Musikanlagen, Partyboxen, Lichttechnik und DJ-Equipment im Großraum Stuttgart. Faire Preise und professionelle Beratung."
  image="/img/vermietung/licht2.webp"
  pagefindType="produkt"
  pagefindMeta={{
    label: "Vermietung",
    image: "/img/vermietung/licht2.webp",
    category: "Vermietung",
    price: "ab 10€"
  }}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
        {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"}
      ]
    },
    faqSchema,
    serviceSchema,
    offerCatalogJsonLd(rentalItems)
  ]}
>
  <Navbar currentPage="/vermietung" />

  <div class="relative">
    <!-- Hero Section -->
    <HeroSlider
      interval={8000}
      slides={[
        {
          title: "Partypaket mieten in Stuttgart – ab 160€/Tag",
          titleTag: "h1",
          description: "Vollständige Sets für Geburtstag, Hochzeit oder Firmenfeier. Plug & Play, inkl. Kabel & Einweisung. Abholung in Leinfelden-Echterdingen.",
          buttons: [
            { text: "Details Partypaket", href: "/vermietung/partypaket-stuttgart" },
            { text: "Jetzt anfragen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/partypaket1.webp",
          ptClass: "pt-32"
        },
        {
          title: "DJ-Paket mieten in Stuttgart – ab 200€/Tag",
          titleTag: "h2",
          description: "Dein komplettes Setup für professionelle DJ Gigs und mittlere Feiern.",
          buttons: [
            { text: "Details DJ-Paket", href: "/vermietung/djpaket-fildern" },
            { text: "Jetzt anfragen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/IMG_6643.webp",
          ptClass: "pt-32"
        },
        {
          title: "Veranstaltungspaket mieten in Stuttgart – ab 200€/Tag",
          titleTag: "h2",
          description: "Das Rundum-Sorglos-Paket für deine mittlere bis große Veranstaltung.",
          buttons: [
            { text: "Details Veranstaltungspaket", href: "/vermietung/veranstaltungspaket-stuttgart" },
            { text: "Jetzt anfragen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/ldmaui3.webp",
          ptClass: "pt-32"
        },
        {
          title: "Akku-Party-Paket mieten – ab 170€/Tag",
          titleTag: "h2",
          description: "Komplett akkubetrieben für Outdoor-Partys und Locations ohne Strom. 4-6h Laufzeit.",
          buttons: [
            { text: "Details Akku-Party-Paket", href: "/vermietung/akku-party-paket" },
            { text: "Jetzt anfragen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/Akku-powered-party-hero.webp",
          ptClass: "pt-32"
        },
        {
          title: "Karaoke-Paket mieten in Stuttgart – ab 130€/Tag",
          titleTag: "h2",
          description: "Das Rundum-Sorglos-Paket für deine Karaoke-Party. 2x JBL Partyboxen, 2x Mikrofone, Yamaha Mischpult – alles inklusive.",
          buttons: [
            { text: "Details Karaoke-Paket", href: "/vermietung/karaoke-paket" },
            { text: "Jetzt anfragen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/karaoke-paket-hero.webp",
          ptClass: "pt-32"
        }
      ]}
    />

  </div>
  <!-- Section Jump Navigation -->
  <nav class="sticky top-20 z-40 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="max-w-7xl mx-auto px-4 py-3 overflow-x-auto">
      <div class="flex gap-2 min-w-max justify-center">
        <a href="#ablauf" class="section-jump-link">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Ablauf
        </a>
        <a href="#pakete" class="section-jump-link">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          Pakete
        </a>
        <a href="#sound" class="section-jump-link">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
          Sound
        </a>
        <a href="#licht" class="section-jump-link">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          Licht
        </a>
        <a href="#kontakt" class="section-jump-link">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Anfragen
        </a>
      </div>
    </div>
  </nav>

  <!-- Intro Section -->
  <section id="ablauf" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Vermietung von Musikanlagen, PA Anlagen, Partyboxen und mehr!</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Vermietung von Veranstaltungstechnik im Großraum Stuttgart, Leinfelden-Echterdingen, Tübingen, Esslingen und Umkreis. Ich vermiete Partyboxen, PA-Anlagen, Musikanlagen, Lautsprecher, DJ-Equipment, Lichttechnik und Beleuchtung für private Feiern, Firmen-Events, Vereinsfeiern, Messen und sonstige Veranstaltungen. <br />
        Anders als Versandverleiher, die dir die Technik per Paket schicken, hast du bei mir die Geräte vorab in der Hand. Du siehst, hörst und testest alles vor Ort – kein Risiko, dass die Technik nicht ankommt oder nicht funktioniert. Und während viele Online-Verleiher Wochen Vorlauf brauchen, reicht bei mir oft eine kurze Anfrage 1-3 Tage vor deiner Feier. <br />
        Faire Preise, flexible Mietzeiträume und persönliche Beratung. Abholung in Leinfelden-Echterdingen, Lieferung auf Anfrage. Ich helfe Dir, die passende Technik für Deine Veranstaltung zu finden und gebe Dir eine ausführliche Einweisung. <br />
        Ich biete schnelle Reaktionszeiten, auch bei kurzfristigen Anfragen. Bitte melde dich am besten telefonisch, damit ich dir schnell sagen kann, ob die gewünschte Technik noch verfügbar ist. Ich habe oft auch kurzfristig noch Geräte verfügbar!
      </p>

      <MietanfrageAblauf />
    </div>
  </section>

  <!-- Komplettpakete -->
  <section id="pakete" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Komplettpakete</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Alles aus einer Hand</h2>
      </div>
      
      <PackageCardGrid pakete={komplettPakete} />
    </div>
  </section>

  <!-- Sound Equipment -->
  <section id="sound" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Sound</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">PA-Anlagen & Lautsprecher</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {soundEquipment.map((item, index) => (
          <div id={`item-${item.slug}`} class="equipment-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="relative">
              <img src={item.image} alt={item.title} width="400" height="256" loading="lazy" decoding="async" class="rounded-xl w-full h-64 object-cover mb-4 bg-[var(--color-surface)]" />
              <span class="plug-badge">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Inkl. Kabel & Einweisung
              </span>
            </div>
            <span class="price-badge">{item.price}</span>
            <h3 class="text-xl font-bold mt-2 mb-3">{item.title}</h3>
            <p class="text-[var(--color-text-muted)] text-sm mb-4">{item.description}</p>
            <ul class="text-[var(--color-text-muted)] text-sm space-y-1">
              {item.features.map(feature => (
                <li class="flex items-center gap-2">
                  <span class="text-[var(--color-secondary)]">•</span> {feature}
                </li>
              ))}
            </ul>
            <a href="#kontakt" class="btn-primary w-full text-center mt-4 block">Jetzt anfragen</a>
            {item.detailPage && !item.detailPage.includes('#') && (
              <a href={item.detailPage} class="btn-secondary w-full text-center mt-3 block" transition:name={`product-${item.slug}`}>Mehr Infos</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Licht Equipment -->
  <section id="licht" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Licht</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Lichttechnik & Effekte</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {lichtEquipment.map((item, index) => (
          <div id={`item-${item.slug}`} class="equipment-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="relative">
              <img src={item.image} alt={item.title} width="400" height="256" loading="lazy" decoding="async" class="rounded-xl w-full h-64 object-cover mb-4 bg-[var(--color-surface)]" />
              <span class="plug-badge">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Inkl. Kabel & Einweisung
              </span>
            </div>
            <span class="price-badge">{item.price}</span>
            <h3 class="text-xl font-bold mt-2 mb-3">{item.title}</h3>
            <p class="text-[var(--color-text-muted)] text-sm mb-4">{item.description}</p>
            <ul class="text-[var(--color-text-muted)] text-sm space-y-1">
              {item.features.map(feature => (
                <li class="flex items-center gap-2">
                  <span class="text-[var(--color-secondary)]">•</span> {feature}
                </li>
              ))}
            </ul>
            <a href="#kontakt" class="btn-primary w-full text-center mt-4 block">Jetzt anfragen</a>
            {item.detailPage && !item.detailPage.includes('#') && (
              <a href={item.detailPage} class="btn-secondary w-full text-center mt-3 block" transition:name={`product-${item.slug}`}>Mehr Infos</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  
  

  <!-- Contact Form Section -->
  <section id="kontakt" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Kontakt</span>
      <h2 class="font-play text-4xl font-bold mt-4 mb-6">Technik anfragen</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Frage gleich unverbindlich über das Formular Deine Wunschtechnik an. Oder schreibe mir eine Email an holger.kampffmeyer+dj@gmail.com
      </p>
      <div class="bg-[var(--color-surface)] rounded-xl p-4 h-[1300px]">
        <iframe 
          src="https://docs.google.com/forms/d/e/1FAIpQLScdCjmRzpquqq0SkGiemkhvMDKPWWnsMvUVCHgkSphwJQ152A/viewform?embedded=true" 
          style="width: 100%; height: 100%; border: none;" 
          loading="lazy"
          title="Vermietungsformular"
        ></iframe>
      </div>
    </div>
  </section>

  <FAQSection faqs={faqs} />
  <Testimonials />

  <Footer />
</Layout>

<style>
  .section-jump-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }
  .section-jump-link:hover {
    color: var(--color-text);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .section-jump-link:active {
    transform: scale(0.97);
  }
</style>
