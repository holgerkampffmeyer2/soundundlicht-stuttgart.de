---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQSection from '../components/FAQSection.astro';
import MietanfrageAblauf from '../components/vermietung/MietanfrageAblauf.astro';
import Icon from '../components/Icon.astro';
import ContactForm from '../components/ContactForm.astro';
import HeroSlider from "../components/HeroSlider.astro";
import { getCollection } from 'astro:content';
import { getFaqsForPage } from '../lib/faqUtils';
import { serviceArea, offerCatalogJsonLd } from '../data/jsonLd';
import PackageCardGrid from '../components/PackageCardGrid.astro';
import StickyMerkliste from '../components/StickyMerkliste.astro';

const products = await getCollection('products');
const rentalItems = products.map(i => i.data);
const faqs = await getFaqsForPage('vermietung');

// Map for quick product lookup by slug
const productMap = Object.fromEntries(rentalItems.map(p => [p.slug, p]));

function getWebpUrl(src: string): string {
  // Convert JPG/PNG to WebP, keep WebP as-is
  return src.replace(/\.(jpe?g|png)$/i, '.webp');
}

function getThumbUrl(src: string): string {
  // Generate thumbnail path: filename-thumb.webp
  return src.replace(/\.[^.]+$/, '-thumb.webp');
}

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung",
  "description": "Verleih von Musikanlagen, Partyboxen, Lichttechnik und DJ-Equipment im Großraum Stuttgart",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  },
  "areaServed": serviceArea
};

const komplettPakete = rentalItems.filter(i => i.category === 'Paket');
const soundEquipment = rentalItems.filter(i => i.category === 'Sound');
const lichtEquipment = rentalItems.filter(i => i.category === 'Licht');
---
<Layout 
  title="Vermietung - Sound und Licht Stuttgart - Partyboxen, Lichttechnik und DJ-Equipment mieten"
  description="Verleih von Musikanlagen, Partyboxen, Lichttechnik und DJ-Equipment im Großraum Stuttgart. Faire Preise und professionelle Beratung."
  image="/img/vermietung/licht2.webp"
  pagefindType="produkt"
  pagefindMeta={{
    label: "Vermietung",
    image: "/img/vermietung/licht2.webp",
    category: "Vermietung",
    price: "ab 10€"
  }}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
        {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"}
      ]
    },
    faqSchema,
    serviceSchema,
    offerCatalogJsonLd(rentalItems)
  ]}
>
  <Navbar currentPage="/vermietung" />

  <div class="relative">
    <!-- Hero Section -->
    <HeroSlider
      interval={8000}
      slides={[
        {
          title: "Partypaket mieten in Stuttgart – ab 160€/Tag",
          titleTag: "h1",
          description: "Vollständige Sets für Geburtstag, Hochzeit oder Firmenfeier. Plug & Play, inkl. Kabel & Einweisung. Abholung in Leinfelden-Echterdingen.",
          buttons: [
            { text: "Details Partypaket", href: "/vermietung/partypaket-stuttgart" },
            { text: "Zur Anfrage hinzufügen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/partypaket1.webp",
          ptClass: "pt-32"
        },
        {
          title: "DJ-Paket mieten in Stuttgart – ab 200€/Tag",
          titleTag: "h2",
          description: "Dein komplettes Setup für professionelle DJ Gigs und mittlere Feiern.",
          buttons: [
            { text: "Details DJ-Paket", href: "/vermietung/djpaket-fildern" },
            { text: "Zur Anfrage hinzufügen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/IMG_6643.webp",
          ptClass: "pt-32"
        },
        {
          title: "Veranstaltungspaket mieten in Stuttgart – ab 200€/Tag",
          titleTag: "h2",
          description: "Das Rundum-Sorglos-Paket für deine mittlere bis große Veranstaltung.",
          buttons: [
            { text: "Details Veranstaltungspaket", href: "/vermietung/veranstaltungspaket-stuttgart" },
            { text: "Zur Anfrage hinzufügen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/ldmaui3.webp",
          ptClass: "pt-32"
        },
        {
          title: "Akku-Party-Paket mieten – ab 170€/Tag",
          titleTag: "h2",
          description: "Komplett akkubetrieben für Outdoor-Partys und Locations ohne Strom. 4-6h Laufzeit.",
          buttons: [
            { text: "Details Akku-Party-Paket", href: "/vermietung/akku-party-paket" },
            { text: "Zur Anfrage hinzufügen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/Akku-powered-party-hero.webp",
          ptClass: "pt-32"
        },
        {
          title: "Karaoke-Paket mieten in Stuttgart – ab 130€/Tag",
          titleTag: "h2",
          description: "Das Rundum-Sorglos-Paket für deine Karaoke-Party. 2x JBL Partyboxen, 2x Mikrofone, Yamaha Mischpult – alles inklusive.",
          buttons: [
            { text: "Details Karaoke-Paket", href: "/vermietung/karaoke-paket" },
            { text: "Zur Anfrage hinzufügen", href: "#kontakt", class: "btn-secondary" }
          ],
          backgroundImage: "/img/vermietung/karaoke-paket-hero.webp",
          ptClass: "pt-32"
        }
      ]}
    />
  </div>

  <!-- Section Jump Navigation -->
  <nav class="sticky top-20 z-40 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="max-w-7xl mx-auto px-4 py-3 overflow-x-auto">
      <div class="flex gap-2 min-w-max justify-center">
        <a href="#ablauf" class="section-jump-link">
          <Icon name="info" class="w-4 h-4" />
          Ablauf
        </a>
        <a href="#pakete" class="section-jump-link">
          <Icon name="package" class="w-4 h-4" />
          Pakete
        </a>
        <a href="#sound" class="section-jump-link">
          <Icon name="volume-up" class="w-4 h-4" />
          Sound
        </a>
        <a href="#licht" class="section-jump-link">
          <Icon name="light-bulb" class="w-4 h-4" />
          Licht
        </a>
        <a href="#kontakt" class="section-jump-link">
          <Icon name="email" class="w-4 h-4" />
          Anfrage
        </a>
      </div>
    </div>
  </nav>

  <!-- Intro Section -->
  <section id="ablauf" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Vermietung von Musikanlagen, PA Anlagen, Partyboxen und mehr!</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Vermietung von Veranstaltungstechnik im Großraum Stuttgart, Leinfelden-Echterdingen, Tübingen, Esslingen und Umkreis. Ich vermiete Partyboxen, PA-Anlagen, Lautsprecher, DJ-Equipment, Lichttechnik und Beleuchtung für private Feiern, Firmen-Events, Vereinsfeiern, Messen und sonstige Veranstaltungen.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-secondary)] transition-all duration-300">
          <div class="icon-circle icon-circle-secondary mb-3 w-10 h-10">
            <Icon name="eye" class="w-5 h-5" />
          </div>
          <h3 class="font-bold text-base mb-1">Vor Ort testen</h3>
          <p class="text-[var(--color-text-muted)] text-sm">Technik vor Abholung ansehen & ausprobieren – kein Überraschungspaket.</p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-secondary)] transition-all duration-300">
          <div class="icon-circle icon-circle-primary mb-3 w-10 h-10">
            <Icon name="clock" class="w-5 h-5" />
          </div>
          <h3 class="font-bold text-base mb-1">Kurzfristig möglich</h3>
          <p class="text-[var(--color-text-muted)] text-sm">1-3 Tage Vorlauf reichen oft. Auch kurzfristige Anfragen sind willkommen.</p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-secondary)] transition-all duration-300">
          <div class="icon-circle icon-circle-accent mb-3 w-10 h-10">
            <Icon name="badge-check" class="w-5 h-5" />
          </div>
          <h3 class="font-bold text-base mb-1">Kein Lieferrisiko</h3>
          <p class="text-[var(--color-text-muted)] text-sm">Geräte sind garantiert da am Tag der Party – keine Versandpannen.</p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-secondary)] transition-all duration-300">
          <div class="icon-circle icon-circle-secondary mb-3 w-10 h-10">
            <Icon name="chat" class="w-5 h-5" />
          </div>
          <h3 class="font-bold text-base mb-1">Persönliche Beratung</h3>
          <p class="text-[var(--color-text-muted)] text-sm">Faire Preise, flexible Mietzeiträume und ausführliche Einweisung vor Ort.</p>
        </div>
      </div>

      <div class="bg-[var(--color-surface)] border border-[var(--color-secondary)]/20 rounded-xl p-4 mb-8">
        <p class="text-[var(--color-text-muted)] text-sm flex items-center gap-2">
          <Icon name="phone" class="w-5 h-5 text-[var(--color-secondary)] shrink-0" />
          <span><strong class="text-[var(--color-text)]">Telefonische Verfügbarkeitsprüfung:</strong> Am besten meldest du dich telefonisch, damit ich dir schnell sagen kann, ob die gewünschte Technik noch verfügbar ist. Ich habe oft auch kurzfristig noch Geräte frei!</span>
        </p>
      </div>

      <MietanfrageAblauf />
    </div>
  </section>

  <!-- Komplettpakete -->
  <section id="pakete" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Komplettpakete</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Alles aus einer Hand</h2>
      </div>
      
      <PackageCardGrid pakete={komplettPakete} />
    </div>
  </section>

  <!-- Sound Equipment -->
  <section id="sound" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Sound</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">PA-Anlagen & Lautsprecher</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {soundEquipment.map((item, index) => (
          <div id={`item-${item.slug}`} class="equipment-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="relative">
              <picture>
                <source srcset={`${getThumbUrl(item.image)} 480w, ${getWebpUrl(item.image)} 960w`} type="image/webp" />
                <img src={item.image} alt={item.title} width="400" height="256" loading="lazy" decoding="async" class="rounded-xl w-full h-64 object-cover mb-4 bg-[var(--color-surface)]" />
              </picture>
              <span class="plug-badge">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Inkl. Kabel & Einweisung
              </span>
            </div>
            <div class="flex items-center gap-1">
              <span class="price-badge">{item.price}</span>
              <span class="price-info-wrap">
                <svg class="price-info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                </svg>
                <span class="price-info-popup">Unverbindliche Preisangabe. Das finale Angebot erhalte ich nach Absenden des Formulars.</span>
              </span>
            </div>
            <h3 class="text-xl font-bold mt-2 mb-3">{item.title}</h3>
            <p class="text-[var(--color-text-muted)] text-sm mb-4">{item.description}</p>
            <ul class="text-[var(--color-text-muted)] text-sm space-y-1">
              {item.features.map(feature => (
                <li class="flex items-center gap-2">
                  <span class="text-[var(--color-secondary)]">•</span> {feature}
                </li>
              ))}
            </ul>
             <div class="flex flex-col gap-2">
                 <button data-action="add-to-wishlist" data-slug={item.slug} class="btn-primary w-full !px-3">
                    <span class="grid grid-cols-[auto_1fr] gap-4 items-start text-left">
                      <Icon name="heart" class="w-6 h-6 mt-0.5 shrink-0" />
                      <span class="text-base leading-tight">Merken</span>
                    </span>
                  </button>
                  {item.detailPage && !item.detailPage.includes('#') && (
                    <a href={item.detailPage} class="btn-secondary w-full text-center block">Mehr Infos</a>
                  )}
                </div>
             </div>
           ))}
         </div>
       </div>
     </section>

     <!-- Licht Equipment -->
   <section id="licht" class="section-padding bg-[var(--color-surface)]">
     <div class="max-w-7xl mx-auto">
       <div class="text-center mb-12">
         <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Licht</span>
         <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Lichttechnik & Effekte</h2>
       </div>
       
       <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
         {lichtEquipment.map((item, index) => (
           <div id={`item-${item.slug}`} class="equipment-card" style={`animation-delay: ${index * 0.1}s`}>
             <div class="relative">
               <picture>
                 <source srcset={`${getThumbUrl(item.image)} 480w, ${getWebpUrl(item.image)} 960w`} type="image/webp" />
                 <img src={item.image} alt={item.title} width="400" height="256" loading="lazy" decoding="async" class="rounded-xl w-full h-64 object-cover mb-4 bg-[var(--color-surface)]" />
               </picture>
               <span class="plug-badge">
                 <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                 Inkl. Kabel & Einweisung
               </span>
             </div>
              <div class="flex items-center gap-1">
                <span class="price-badge">{item.price}</span>
                <span class="price-info-wrap">
                  <svg class="price-info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                  </svg>
                  <span class="price-info-popup">Unverbindliche Preisangabe. Das finale Angebot erhalte ich nach Absenden des Formulars.</span>
                </span>
              </div>
              <h3 class="text-xl font-bold mt-2 mb-3">{item.title}</h3>
              <p class="text-[var(--color-text-muted)] text-sm mb-4">{item.description}</p>
              <ul class="text-[var(--color-text-muted)] text-sm space-y-1">
                {item.features.map(feature => (
                  <li class="flex items-center gap-2">
                    <span class="text-[var(--color-secondary)]">•</span> {feature}
                  </li>
                ))}
              </ul>
               <div class="flex flex-col gap-2">
                    <button data-action="add-to-wishlist" data-slug={item.slug} class="btn-primary w-full !px-3">
                      <span class="grid grid-cols-[auto_1fr] gap-4 items-start text-left">
                       <Icon name="heart" class="w-6 h-6 mt-0.5 shrink-0" />
                       <span class="text-base leading-tight">Merken</span>
                     </span>
                   </button>
                 {item.detailPage && !item.detailPage.includes('#') && (
                   <a href={item.detailPage} class="btn-secondary w-full text-center block">Mehr Infos</a>
                 )}
               </div>
           </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="kontakt" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Kontakt</span>
      <h2 class="font-play text-4xl font-bold mt-4 mb-6">Technik anfragen</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Frage gleich unverbindlich über das Formular Deine Wunschtechnik an. Oder schreibe mir eine Email an holger.kampffmeyer+dj@gmail.com
      </p>
      <ContactForm />
    </div>
  </section>

  <FAQSection faqs={faqs} />
  <Testimonials />
  <StickyMerkliste />
  <Footer />
</Layout>

<script>
  import { addItem } from '../lib/merklisteStore';

  document.addEventListener('click', (e) => {
    const target = e.target.closest('[data-action="add-to-wishlist"]');
    if (!target) return;
    if (target.closest('#pakete')) return;
    const slug = target.dataset.slug;
    if (!slug) return;

    addItem(slug);

    target.innerHTML = '<span class="grid grid-cols-[auto_1fr] gap-4 items-start text-left"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-base leading-tight">Gemerkt (1)</span></span>';

    const badge = document.querySelector('.merkliste-badge');
    if (badge) {
      const items = JSON.parse(localStorage.getItem('sls_merkliste') || '{}').items || [];
      const totalItems = items.reduce((sum, i) => sum + i.quantity, 0);
      badge.textContent = totalItems;
      badge.classList.toggle('hidden', totalItems === 0);
    }
  });
</script>

<style>
  .section-jump-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }
  .section-jump-link:hover {
    color: var(--color-text);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .section-jump-link:active {
    transform: scale(0.97);
  }
</style>