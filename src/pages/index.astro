---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import VolumeUpIcon from "../components/icons/VolumeUpIcon.astro";
import LightBulbIcon from "../components/icons/LightBulbIcon.astro";
import PackageIcon from "../components/icons/PackageIcon.astro";
import MapPinIcon from "../components/icons/MapPinIcon.astro";
import EmailIcon from "../components/icons/EmailIcon.astro";
import Testimonials from "../components/Testimonials.astro";
import CityGrid from "../components/CityGrid.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';
import BieteSection from "../components/BieteSection.astro";

const indexFaqs = getFaqsForPage('index');

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": indexFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const offerCatalogJsonLd = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Vermietung Pakete",
  "itemListElement": [
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Partypaket"
      },
      "price": "160.00",
      "priceCurrency": "EUR"
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "DJ-Paket"
      },
      "price": "200.00",
      "priceCurrency": "EUR"
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Veranstaltungspaket"
      },
      "price": "180.00",
      "priceCurrency": "EUR"
    }
  ]
};

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung",
  "description": "Verleih von PA-Anlagen, Partyboxen, Lichttechnik und DJ-Equipment in Stuttgart und Umgebung",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Sound & Licht Stuttgart - Holger Kampffmeyer",
    "url": "https://soundundlicht-stuttgart.de"
  },
  "areaServed": {
    "@type": "State",
    "name": "Baden-Württemberg"
  }
};

const galleryImages = [
  { 
    src: "/img/vermietung/licht1.webp", 
    fallback: "/img/vermietung/licht1.jpg", 
    alt: "2x LD Maui 28 G3 Säulen-PA, Lichtanlage + Nebelmaschine",
    category: "Komplettset Sound & Licht",
    useCase: "Geburtstagsfeier, Party",
    equipment: "2x LD Maui 28 G3 Säulen-PA, Lichtanlage + Nebelmaschine",
    persons: "50-100 Personen",
    simplicity: "Plug & Play, in 5 Min. aufgebaut",
    detailPage: "/vermietung/ld-maui-28g3/"
  },
  { 
    src: "/img/vermietung/licht2.webp", 
    fallback: "/img/vermietung/licht2.jpg", 
    alt: "LD Maui 28 G3 Säulen-PA",
    category: "PA-Anlage",
    useCase: "Vereinsfeier, Firmenfeier",
    equipment: "LD Maui 28 G3 Säulen-PA",
    persons: "bis 150 Personen",
    simplicity: "2060W Peak, professioneller Sound",
    detailPage: "/vermietung/ld-maui-28g3/"
  },
  { 
    src: "/img/vermietung/anlage1.webp", 
    fallback: "/img/vermietung/anlage1.jpg", 
    alt: "LD Maui 28 G3 Säulen-PA mit Lichtanlage",
    category: "PA-Anlage und Lichttechnik",
    useCase: "Firmenfeier, Private Feier",
    equipment: "LD Maui 28 G3 Säulen-PA, Partylichtanlage",
    persons: "bis 150 Personen",
    simplicity: "Kraftvoller Sound, beeindruckende Lichteffekte, einfacher Aufbau",
    detailPage: "/vermietung/veranstaltungspaket-stuttgart/"
  },
  { 
    src: "/img/vermietung/anlage2.webp", 
    fallback: "/img/vermietung/anlage2.jpg", 
    alt: "LD Maui 28 G3 Säulen-PA",
    category: "PA-Anlage",
    useCase: "Hochzeiten, Vereinsfeier",
    equipment: "LD Maui 28 G3 Säulen-PA",
    persons: "bis 150 Personen",
    simplicity: "2060W Peak, professioneller Sound, einfacher Aufbau",
    detailPage: "/vermietung/ld-maui-28g3/"
  },
  { 
    src: "/img/vermietung/jbl-set1.webp", 
    fallback: "/img/vermietung/jbl-set1.jpg", 
    alt: "JBL Partybox Set (2x)",
    category: "Partyboxen",
    useCase: "Private Feiern, Gartenparty",
    equipment: "JBL Partybox Set (2x)",
    persons: "50-80 Personen",
    simplicity: "Dynamic Light Effects, Bluetooth",
    detailPage: "/vermietung/jbl-partybox-300-320/"
  },
  { 
    src: "/img/vermietung/ldmaui3.webp", 
    fallback: "/img/vermietung/ldmaui3.jpg", 
    alt: "2x LD Maui 28 G3 Säulen-PA",
    category: "PA-Anlage",
    useCase: "Firmenfeier, Hochzeit",
    equipment: "2x LD Maui 28 G3 Säulen-PA",
    persons: "bis 150",
    simplicity: "2060W Peak, professioneller Sound",
    detailPage: "/vermietung/ld-maui-28g3/"
  },
  { 
    src: "/img/vermietung/licht3.webp", 
    fallback: "/img/vermietung/licht3.jpg", 
    alt: "LD Maui 28 G3 Säulen-PA und Partylichtanlage",
    category: "Komplettset Sound & Licht",
    useCase: "Lichtshow, Party",
    equipment: "LD Maui 28 G3 Säulen-PA und Partylichtanlage",
    persons: "50-100 Personen",
    simplicity: "Einfacher Aufbau, Sound-zu-Licht Modus",
    detailPage: "/vermietung/veranstaltungspaket-stuttgart/"
  },
  { 
    src: "/img/vermietung/stairville-led-bossfx-2-pro-2.webp", 
    fallback: "/img/vermietung/stairville-led-bossfx-2-pro-2.jpg", 
    alt: "LED BossFX-2 Pro + Nebelmaschine",
    category: "Partylichtanlagen",
    useCase: "Events, Hochzeiten",
    equipment: "LED BossFX-2 Pro + Nebelmaschine",
    persons: "50-100 Personen",
    simplicity: "Inkl. Stativ",
    detailPage: "/vermietung/led-bossfx-nebelmaschine/"
  }
];
---

<Layout
  title="Partytechnik mieten Stuttgart | Sound & Licht Verleih - Leinfelden-Echterdingen, Esslingen, Tübingen"
  description="Vermietung von PA-Anlagen, Partyboxen & Lichttechnik in Stuttgart, Leinfelden-Echterdingen, Esslingen, Tübingen. Ab 160€ pro Tag. DJ-Service, persönliche Beratung, einfache Abholung."
  image="/img/header.webp"
  jsonLd={[serviceJsonLd, faqJsonLd, offerCatalogJsonLd]}
>
  <Navbar currentPage="home" />

  <!-- Hero Slider -->
  <section id="home" class="hero-slider">
    <!-- Slide 1 -->
    <div class="slide slide-1 active" data-slide="0">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase mb-4 block">
              Dein lokaler Verleih für Partylicht, Partyboxen und Veranstaltungstechnik
            </span>
            <h1 class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text">
              Sound & Licht Stuttgart
            </h1>
            <p class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-4 max-w-2xl">
              Du planst eine Geburtstagsparty, Hochzeit, Firmenfeier oder ein Karaoke-Event? Ich bin Dein lokaler Verleiher von Lautsprechern, Musikanlagen, Partyboxen, Lichttechnik und DJ-Equipment in Stuttgart, Leinfelden-Echterdingen, Esslingen, Tübingen und Umgebung.
            </p>
            
<div class="flex flex-col sm:flex-row gap-4">
              <a href="/vermietung/" class="btn-primary neon-pulse">Zur Vermietung ↗</a>
              <a href="#kontakt" class="btn-secondary">Kontakt aufnehmen</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="slide slide-2" data-slide="1">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span class="text-[var(--color-accent)] text-lg tracking-widest uppercase mb-4 block">
              Jetzt mieten
            </span>
            <h2 class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text">
              Technik für dein Event
            </h2>
            <p class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl">
               Kraftvoller Sound, beeindruckende Lichteffekte und professionelle Ausrüstung für unvergessliche Feiern.
             </p>
             
             <!-- Soundwave Visual -->
<div class="flex flex-col sm:flex-row gap-4">
              <a href="/vermietung/" class="btn-primary neon-pulse">Zur Vermietung ↗</a>
              <a href="#kontakt" class="btn-secondary">Kontakt aufnehmen</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slider Navigation -->
    <button class="slider-nav prev" id="slider-prev">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button class="slider-nav next" id="slider-next">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Slider Dots -->
    <div class="slider-dots">
      <div class="slider-dot active" data-dot="0"></div>
      <div class="slider-dot" data-dot="1"></div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-float z-20">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
          Unsere Leistungen
        </span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Was ich dir biete
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-3xl mx-auto">
          Professionelle Veranstaltungstechnik, Partyboxen und Lichttechnik für deine Feier in Stuttgart, Leinfelden-Echterdingen, Esslingen, Tübingen, Kornwestheim und Umgebung. Egal ob Geburtstag, Hochzeit, Vereinsfeier oder Firmenfeier – ich habe die passende Technik für unvergessliche Events. Einfach mieten, abholen und losfeiern!
        </p>
      </div>

      <BieteSection />

      <div class="text-center mt-12 animate-on-scroll">
        <a href="/vermietung/" class="btn-primary">
          Technik aussuchen &amp; anfragen ↗
        </a>
      </div>
    </div>
  </section>

  <!-- Pakete Section -->
  <section id="pakete" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
          Pakete
        </span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Unsere Komplettpakete
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-3xl mx-auto">
          Alles aus einer Hand – Sound, Licht und Effekte als fertiges Paket. Plug &amp; Play, inklusive Kabel und Einweisung.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Paket 1: Partypaket -->
        <div class="service-card animate-on-scroll flex flex-col">
          <div class="text-[var(--color-secondary)] mb-4"><VolumeUpIcon class="w-10 h-10" /></div>
          <h3 class="font-play text-xl font-bold mb-2">Partypaket</h3>
          <p class="text-sm text-[var(--color-accent)] font-semibold mb-4">ab 160€ / Tag</p>
          <p class="text-[var(--color-text-muted)] text-sm mb-4">Für kleinere Feiern bis ca. 50 Personen</p>
          <ul class="text-[var(--color-text-muted)] text-sm space-y-1.5 mb-6 flex-1">
            <li>✓ 2x JBL Partyboxen</li>
            <li>✓ KLS Laser Bar</li>
            <li>✓ Nebelmaschine</li>
            <li>✓ Mikrofon</li>
            <li>✓ 4x LED Par Lichter</li>
          </ul>
          <a href="/vermietung/partypaket-stuttgart/" class="btn-primary text-center text-sm py-2.5 px-4 mt-auto">
            Details &amp; Buchung ↗
          </a>
        </div>

        <!-- Paket 2: DJ-Paket -->
        <div class="service-card animate-on-scroll flex flex-col">
          <div class="text-[var(--color-secondary)] mb-4"><VolumeUpIcon class="w-10 h-10" /></div>
          <h3 class="font-play text-xl font-bold mb-2">DJ-Paket</h3>
          <p class="text-sm text-[var(--color-accent)] font-semibold mb-4">ab 200€ / Tag</p>
          <p class="text-[var(--color-text-muted)] text-sm mb-4">Für DJ Gigs &amp; mittlere Feiern bis ca. 150 Personen</p>
          <ul class="text-[var(--color-text-muted)] text-sm space-y-1.5 mb-6 flex-1">
            <li>✓ 2x LD Maui 28 G3</li>
            <li>✓ LED BossFX-2 Pro + Nebel</li>
            <li>✓ Moving Head</li>
            <li>✓ Stage Bar</li>
            <li>✓ Mikrofon + 4x LED Par</li>
          </ul>
          <a href="/vermietung/djpaket-fildern/" class="btn-primary text-center text-sm py-2.5 px-4 mt-auto">
            Details &amp; Buchung ↗
          </a>
        </div>

        <!-- Paket 3: Veranstaltungspaket -->
        <div class="service-card animate-on-scroll flex flex-col">
          <div class="text-[var(--color-secondary)] mb-4"><PackageIcon class="w-10 h-10" /></div>
          <h3 class="font-play text-xl font-bold mb-2">Veranstaltungspaket</h3>
          <p class="text-sm text-[var(--color-accent)] font-semibold mb-4">ab 180€ / Tag</p>
          <p class="text-[var(--color-text-muted)] text-sm mb-4">Für mittlere bis große Veranstaltungen bis ca. 150 Personen</p>
          <ul class="text-[var(--color-text-muted)] text-sm space-y-1.5 mb-6 flex-1">
            <li>✓ 2x LD Maui 28 G3</li>
            <li>✓ 6-Kanal Mischpult</li>
            <li>✓ KLS Laser Bar + Nebel</li>
            <li>✓ 2x Moving Head</li>
            <li>✓ Mikrofon + 4x LED Par</li>
          </ul>
          <a href="/vermietung/veranstaltungspaket-stuttgart/" class="btn-primary text-center text-sm py-2.5 px-4 mt-auto">
            Details &amp; Buchung ↗
          </a>
        </div>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a href="/vermietung/" class="btn-secondary">
          Alle Pakete und Einzelgeräte ansehen ↗
        </a>
      </div>
    </div>
  </section>

  <!-- Galerie Section -->
  <section id="galerie" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
          Verleih & Vermietung
        </span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Unsere Veranstaltungstechnik
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-3xl mx-auto">
          Vermietung / Verleih von Veranstaltungstechnik im Großraum Stuttgart, Leinfelden-Echterdingen, Tübingen, Esslingen und Umkreis. Ich vermiete Partyboxen, Musikanlagen, DJ-Equipment, Lichttechnik und Beleuchtung für deine privaten Feiern, Firmen-Events, Vereinsfeiern, Messen und sonstige Veranstaltungen.
        </p>
      </div>

      <div class="gallery-grid">
        {galleryImages.map((img, index) => (
          <a href="/vermietung/" class="gallery-item animate-on-scroll block" style={`animation-delay: ${index * 0.1}s`}>
            <picture>
              <source srcset={img.src} type="image/webp" />
              <img src={img.fallback || img.src} alt={img.alt} loading="lazy" />
            </picture>
            <div class="gallery-info">
              <span class="gallery-category">{img.category}</span>
              <span class="gallery-usecase">{img.useCase}</span>
              <span class="gallery-details">
                {img.equipment} • {img.persons} • {img.simplicity}
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a href="/vermietung/" class="btn-secondary">
          Alle Geräte ansehen ↗
        </a>
      </div>
    </div>
  </section>

  <!-- So funktioniert's Section -->
  <section id="ablauf" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
          Ablauf
        </span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          So einfach mietest du
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-3xl mx-auto">
          In vier Schritten zur perfekten Partytechnik – unkompliziert, persönlich und fair.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="service-card animate-on-scroll text-center">
          <div class="text-4xl font-bold text-[var(--color-secondary)] mb-3">1</div>
          <h3 class="font-play text-lg font-bold mb-2">Anfragen</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Schreib mir eine E-Mail mit deiner Wunschtechnik und dem Mietzeitraum.
          </p>
        </div>

        <div class="service-card animate-on-scroll text-center">
          <div class="text-4xl font-bold text-[var(--color-secondary)] mb-3">2</div>
          <h3 class="font-play text-lg font-bold mb-2">Bestätigen</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Ich melde mich innerhalb von 12 Stunden mit einem fairen Angebot bei dir.
          </p>
        </div>

        <div class="service-card animate-on-scroll text-center">
          <div class="text-4xl font-bold text-[var(--color-secondary)] mb-3">3</div>
          <h3 class="font-play text-lg font-bold mb-2">Abholen</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Hol die Technik in Leinfelden-Echterdingen ab. Bezahlung bar oder per PayPal.
          </p>
        </div>

        <div class="service-card animate-on-scroll text-center">
          <div class="text-4xl font-bold text-[var(--color-secondary)] mb-3">4</div>
          <h3 class="font-play text-lg font-bold mb-2">Feiern</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Aufbauen, loslegen und nach der Feier einfach wieder zurückbringen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- City Grid Section -->
  <CityGrid />

  <!-- FAQ Section -->
  <section id="faq" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={indexFaqs} />
    </div>
  </section>

  <!-- Testimonials Section -->
  <Testimonials id="bewertungen" />

  <!-- DJ Section -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
        DJ Buchen
      </span>
      <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
        Du brauchst einen DJ?
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg mb-8 max-w-3xl mx-auto">
        Ich bin nicht nur dein Ansprechpartner für Veranstaltungstechnik, sondern auch als DJ Hulk auf Hochzeiten, Firmenfeiern und Club-Events unterwegs. House, Tech House, Deep House – ich bringe die Menge zum Tanzen. Musikwünsche werden vorab besprochen und berücksichtigt.
      </p>
      <a href="https://holger-kampffmeyer.de/djhulk-electronic-music" target="_blank" class="btn-primary neon-pulse inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
        </svg>
        DJ Hulk kennenlernen ↗
      </a>
    </div>
  </section>

  <!-- Kontakt Section -->
  <section id="kontakt" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
        Kontakt
      </span>
      <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
        Wir sind für dich da!
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg mb-10">
        Du hast Fragen zur Technik oder möchtest etwas mieten? Kontaktiere uns! Abholung und persönliche Beratung in Leinfelden-Echterdingen, verkehrsgünstig an A8 / B27 gelegen. Unser übliches Einzugsgebiet umfasst Stuttgart, Esslingen, Tübingen und Umgebung. Wir freuen uns auf deine Anfrage!
      </p>

      <div class="grid grid-cols-1 gap-8 mb-12">
        <div class="bg-[var(--color-bg)] rounded-xl p-6">
