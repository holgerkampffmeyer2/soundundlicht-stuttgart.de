---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CityHero from "../components/CityHero.astro";
import CityPackages from "../components/CityPackages.astro";
import CitySteps from "../components/CitySteps.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContactSection from "../components/ContactSection.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Reutlingen" }
];

const cityFaqs = await getFaqsForPage('reutlingen');

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cityFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const cityJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung Reutlingen",
  "description": "PA-Anlagen, Partyboxen und Lichttechnik mieten in Reutlingen und Umgebung. Komplettpakete für Geburtstage, Hochzeiten und Vereinsfeiern. Abholung in Leinfelden-Echterdingen, nur 40 km.",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  },
  "url": "https://soundundlicht-stuttgart.de/reutlingen",
  "areaServed": {
    "@type": "City",
    "name": "Reutlingen"
  }
};
---

<Layout
  title="Veranstaltungstechnik mieten in Reutlingen | Sound & Licht Stuttgart"
  description="PA-Anlagen, Partyboxen und Lichttechnik mieten in Reutlingen und Umgebung. Komplettpakete für Geburtstage, Hochzeiten und Vereinsfeiern. Abholung in Leinfelden-Echterdingen, nur 40 km."
  image="/img/header.webp"
  jsonLd={[cityJsonLd, faqJsonLd]}
>
  <Navbar currentPage="city" />

  <Breadcrumb segments={breadcrumbSegments} />

  <CityHero
    image="/img/cities/reutlingen.webp"
    city="Reutlingen"
    title="Veranstaltungstechnik mieten in Reutlingen"
    description="Du wohnst in Reutlingen, Betzingen, Ohmenhausen oder Umgebung und brauchst eine Soundanlage oder Lichttechnik für deine Feier? Ich bin dein Verleiher direkt um die Ecke."
    details="Mein Standort in Leinfelden-Echterdingen ist nur ca. 40 km von Reutlingen entfernt, gut erreichbar über die B27. Du kannst die Technik bequem abholen, ich helfe dir beim Einladen und erkläre dir den Aufbau. Anders als bei Versandverleihern kannst du die Technik vor der Abholung in Funktion sehen und bekommst eine persönliche Einweisung – so weißt du genau, was dich erwartet."
  />

  <CityPackages />
  <CitySteps />

  <!-- FAQ -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={cityFaqs} />
    </div>
  </section>

  <ContactSection
    title="Technik mieten in Reutlingen – einfach anfragen"
    description="Du wohnst in Reutlingen oder der Umgebung und brauchst Technik? Schreib mir eine E-Mail – die Abholung ist nur 40 km entfernt in Leinfelden-Echterdingen, Magellanstraße 4, verkehrsgünstig an A8. Ich melde mich innerhalb von 12 Stunden bei dir!"
    distanceText="Nur ca. 40 km von Reutlingen"
  />

  <Footer />
</Layout>
