---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CityHero from "../components/CityHero.astro";
import CityPackages from "../components/CityPackages.astro";
import CitySteps from "../components/CitySteps.astro";
import MapPinIcon from "../components/icons/MapPinIcon.astro";
import EmailIcon from "../components/icons/EmailIcon.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Nürtingen" }
];

const cityFaqs = getFaqsForPage('nürtingen');

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cityFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const cityJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung Nürtingen",
  "description": "PA-Anlagen, Partyboxen und Lichttechnik mieten in Nürtingen und Umgebung. Komplettpakete für Geburtstage, Hochzeiten und Vereinsfeiern. Abholung in Leinfelden-Echterdingen, nur 20 km.",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  },
  "url": "https://soundundlicht-stuttgart.de/nürtingen",
  "areaServed": {
    "@type": "City",
    "name": "Nürtingen"
  }
};
---

<Layout
  title="PA-Anlage & Partybox mieten in Nürtingen | Sound & Licht Stuttgart"
  description="PA-Anlagen, Partyboxen und Lichttechnik mieten in Nürtingen und Umgebung. Komplettpakete für Geburtstage, Hochzeiten und Vereinsfeiern. Abholung in Leinfelden-Echterdingen, nur 20 km."
  image="/img/header.webp"
  jsonLd={[cityJsonLd, faqJsonLd]}
>
  <Navbar currentPage="city" />

  <Breadcrumb segments={breadcrumbSegments} />

  <CityHero
    image="/img/cities/nürtingen.webp"
    city="Nürtingen"
    title="PA-Anlage & Partybox mieten in Nürtingen"
    description="Du wohnst in Nürtingen, Roßdorf, Zizishausen oder Umgebung und brauchst eine Soundanlage oder Lichttechnik für deine Feier? Ich bin dein Verleiher direkt um die Ecke."
    details="Mein Standort in Leinfelden-Echterdingen ist nur ca. 20 km von Nürtingen entfernt, gut erreichbar über die A8. Du kannst die Technik bequem abholen, ich helfe dir beim Einladen und erkläre dir den Aufbau. Anders als bei Versandverleihern kannst du die Technik vor der Abholung in Funktion sehen und bekommst eine persönliche Einweisung – so weißt du genau, was dich erwartet."
  />

  <CityPackages />
  <CitySteps />

  <!-- FAQ -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={cityFaqs} />
    </div>
  </section>

  <section id="kontakt" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">
        Kontakt
      </span>
      <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
        Technik mieten in Nürtingen – einfach anfragen
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg mb-10">
        Du wohnst in Nürtingen oder der Umgebung und brauchst Technik? Schreib mir eine E-Mail – die Abholung ist nur 20 km entfernt in Leinfelden-Echterdingen, Magellanstraße 4, verkehrsgünstig an A8. Ich melde mich innerhalb von 12 Stunden bei dir!
      </p>

      <div class="grid grid-cols-1 gap-8 mb-12">
        <div class="bg-[var(--color-bg)] rounded-xl p-6">
          <div class="w-full h-64 md:h-80 rounded-lg overflow-hidden mb-4">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2633.5828618899773!2d9.15913277708782!3d48.69433947131032!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4799c318ddfada49%3A0x8c761bb0db8ae55e!2sHolger%20Kampffmeyer%20DJ%20Dienstleistungen!5e0!3m2!1sde!2sde!4v1773674458531!5m2!1sde!2sde"
              style="border:0; width: 100%; height: 100%;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Google Maps - Sound & Licht Stuttgart">
            </iframe>
          </div>
          <div class="text-[var(--color-secondary)] mb-3"><MapPinIcon class="w-10 h-10" /></div>   
          <h3 class="font-play font-bold mb-2">Adresse (Abholung)</h3>
          <p class="text-[var(--color-text-muted)]">
            Magellanstraße 4<br>
            70771 Leinfelden-Echterdingen<br>
            Nur ca. 20 km von Nürtingen
          </p>
          <a href="https://www.google.com/maps/dir/N%C3%BCrtingen/Magellanstraße+4,+70771+Leinfelden-Echterdingen/" target="_blank" rel="noopener noreferrer nofollow" class="text-[var(--color-secondary)] text-sm hover:underline mt-2 inline-block">
            Route von Nürtingen planen →
          </a>
</div>
        <div class="bg-[var(--color-bg)] rounded-xl p-6">
          <div class="text-[var(--color-secondary)] mb-3"><EmailIcon class="w-10 h-10" /></div>
          <h3 class="font-play font-bold mb-2">E-Mail</h3>
          <p class="text-[var(--color-text-muted)]">
            holger.kampffmeyer+dj@gmail.com
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="mailto:holger.kampffmeyer+dj@gmail.com" class="btn-primary flex items-center justify-center gap-2">
          E-Mail senden
        </a>
        <a href="/vermietung/" class="btn-secondary">
          Alle Details &amp; Geräte ↗
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
