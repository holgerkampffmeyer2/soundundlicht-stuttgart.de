---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CityHero from "../components/CityHero.astro";
import CityPackages from "../components/CityPackages.astro";
import CitySteps from "../components/CitySteps.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContactSection from "../components/ContactSection.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Stuttgart" }
];

const cityFaqs = await getFaqsForPage('stuttgart');

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cityFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const cityJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung Stuttgart",
  "areaServed": {
    "@type": "City",
    "name": "Stuttgart"
  },
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  }
};

const distanceKm = "15";
const travelTime = "20-25";
---

<Layout
  title="PA-Anlage & Partybox mieten in Stuttgart | Sound & Licht Stuttgart"
  description={`Partytechnik mieten in Stuttgart: PA-Anlagen, Partyboxen, Lichttechnik und Komplettpakete für deine Feier. Abholung in Leinfelden-Echterdingen, verkehrsgünstig an A8/B27 – nur ${travelTime} Minuten von Stuttgart.`}
  image="/img/header.webp"
  jsonLd={[cityJsonLd, faqJsonLd]}
>
  <Navbar currentPage="city" />

  <Breadcrumb segments={breadcrumbSegments} />

  <CityHero
    image="/img/cities/stuttgart.webp"
    city="Stuttgart"
    title="PA-Anlage &amp; Partybox mieten in Stuttgart"
    description="Du planst eine Feier in Stuttgart und brauchst zuverlässige Veranstaltungstechnik? Ob Geburtstag im Kreis der Familie, Hochzeit in einer der vielen Stuttgarter Locations oder Firmenfeier im Ballsaal – ich habe die passende Technik für dich."
    details={`Meine Pakete umfassen PA-Anlagen, Partyboxen, Lichttechnik und DJ-Equipment. Die Abholung erfolgt in Leinfelden-Echterdingen – von Stuttgart aus nur ca. ${travelTime} Minuten über die A8 oder B27. Ich erkläre dir den Aufbau und stehe bei Fragen zur Seite. Anders als bei Versandverleihern hast du die Technik vorab in der Hand und bekommst eine persönliche Einweisung – so weißt du genau, was dich erwartet.`}
  />

  <CityPackages />
  <CitySteps />

  <!-- FAQ -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={cityFaqs} />
    </div>
  </section>

  <ContactSection
    title="Technik mieten in Stuttgart – einfach anfragen"
    description={`Du wohnst in Stuttgart oder Umgebung und m\u00f6chtest Technik f\u00fcr deine Party mieten? Schreib mir eine E-Mail mit deinem Wunschdatum und der gew\u00fcnschten Ausr\u00fcstung. Die Abholung ist in Leinfelden-Echterdingen, Magellanstra\u00dfe 4 \u2013 verkehrsg\u00fcnstig an A8 / B27, nur ${distanceKm} km bzw. ${travelTime} Minuten von Stuttgart. Ich melde mich innerhalb von 12 Stunden bei dir!`}
    distanceText={`Nur ${distanceKm} km von Stuttgart \u2013 verkehrsg\u00fcnstig an A8 / B27`}
  />

  <Footer />
</Layout>
