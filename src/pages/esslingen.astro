---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CityHero from "../components/CityHero.astro";
import CityPackages from "../components/CityPackages.astro";
import CitySteps from "../components/CitySteps.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContactSection from "../components/ContactSection.astro";
import FAQSection from "../components/FAQSection.astro";
import { getFaqsForPage } from '../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Esslingen" }
];

const cityFaqs = await getFaqsForPage('esslingen');

const cityJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungstechnik Vermietung Esslingen",
  "areaServed": {
    "@type": "City",
    "name": "Esslingen am Neckar"
  },
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cityFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout
  title="Partybox & PA-Anlage mieten in Esslingen | Sound & Licht Stuttgart"
  description="Veranstaltungstechnik mieten in Esslingen am Neckar: Partyboxen, PA-Anlagen, Lichttechnik und Komplettpakete. Abholung in Leinfelden-Echterdingen, nur 10 km von Esslingen."
  image="/img/header.webp"
  jsonLd={[cityJsonLd, faqJsonLd]}
>
  <Navbar currentPage="city" />

  <Breadcrumb segments={breadcrumbSegments} />

  <CityHero
    image="/img/cities/esslingen.webp"
    city="Esslingen"
    title="Partybox &amp; PA-Anlage mieten in Esslingen"
    description="Du feierst in Esslingen am Neckar und brauchst eine professionelle Musikanlage, Partybeleuchtung oder ein komplettes Sound-Set? Ich bin dein lokaler Verleiher für Veranstaltungstechnik im Großraum Esslingen."
    details="Meine Pakete umfassen PA-Anlagen, Partyboxen und Lichttechnik. Die Abholung ist in Leinfelden-Echterdingen – von Esslingen aus nur ca. 20 km über die A8. Ich berate dich persönlich und gebe eine ausführliche Einweisung. Anders als bei Versandverleihern kannst du die Technik vor der Abholung in Funktion sehen – so weißt du genau, was dich erwartet."
  />

  <CityPackages />
  <CitySteps />

  <!-- FAQ -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <FAQSection faqs={cityFaqs} />
    </div>
  </section>

  <ContactSection
    title="Technik mieten in Esslingen – einfach anfragen"
    description="Du kommst aus Esslingen und suchst Technik für deine Veranstaltung? Schreib mir eine E-Mail mit deinem Wunschdatum und der gewünschten Ausrüstung. Die Abholung ist in Leinfelden-Echterdingen, Magellanstraße 4 – verkehrsgünstig an A8 / B27, nur ca. 10 km von Esslingen. Ich melde mich innerhalb von 12 Stunden bei dir!"
    distanceText="Nur ca. 10 km von Esslingen – verkehrsgünstig an A8 / B27"
  />

  <Footer />
</Layout>
