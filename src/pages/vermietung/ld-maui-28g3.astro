---
import ProductLayout from '../../components/vermietung/ProductLayout.astro';
import Icon from '../../components/Icon.astro';
import TechnicalSpecs from '../../components/vermietung/TechnicalSpecs.astro';
import RentalIncludes from '../../components/vermietung/RentalIncludes.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import { getCollection } from 'astro:content';
import { getFaqsForPage } from '../../lib/faqUtils';

const products = await getCollection('products');
const product = products.find(i => i.data.slug === 'ld-maui-28g3')!.data;

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Vermietung", href: "/vermietung" },
  { label: "LD Maui 28 G3" }
];

const pageTitle = "LD Maui 28 G3 | Sound und Licht Stuttgart - Holger Kampffmeyer";
const faqs = await getFaqsForPage('ld-maui-28g3');

const images = [
  "/img/vermietung/djpaket.webp",
  "/img/vermietung/LDMAUI28G3_1_kl.webp",
  "/img/vermietung/ldmaui2.webp",
  "/img/vermietung/ld-3.webp",
  "/img/vermietung/IMG_4594.webp",
  "/img/vermietung/IMG_3952.webp",
  "/img/vermietung/IMG_4252.webp",
  "/img/vermietung/IMG_4722.webp",
  "/img/vermietung/IMG_6054.webp",
  "/img/vermietung/IMG_6196.webp",
  "/img/vermietung/IMG_6267.webp",
  "/img/vermietung/IMG_7142.webp"
];

const siteUrl = "https://soundundlicht-stuttgart.de";
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "LD Maui 28 G3 Vermietung",
  "description": "Miete das LD Maui 28 G3 Säulensystem für deine Party, Hochzeit oder Firmenfeier. Die LD Maui 28 G3 ist eine professionelle PA-Anlage mit starkem Bass, druckvollem und glasklarem Sound, mit 2060W, 127 dB Schalldruck, für bis zu 150 Personen.",
  "image": [siteUrl + images[0], siteUrl + images[1]],
  "provider": { "@type": "LocalBusiness", "@id": "https://soundundlicht-stuttgart.de/#business" },
  "offers": {
    "@type": "Offer",
    "url": "https://soundundlicht-stuttgart.de/vermietung/ld-maui-28g3",
    "price": product.priceValue.toString(),
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "LD Maui 28 G3 Vermietung",
  "description": "Miete das LD Maui 28 G3 Säulensystem für deine Party, Hochzeit oder Firmenfeier. Die LD Maui 28 G3 ist eine professionelle PA-Anlage mit starkem Bass, druckvollem und glasklarem Sound, mit 2060W, 127 dB Schalldruck, für bis zu 150 Personen.",
  "image": [siteUrl + images[0], siteUrl + images[1]],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "15",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Kunde" },
      "datePublished": "2024-06-15",
      "reviewBody": "Tolles Set, einfache Handhabung, gerne wieder!",
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": "5",
        "bestRating": "5"
      }
    }
  ],
  "offers": {
    "@type": "Offer",
    "price": product.priceValue.toString(),
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  },
  "brand": {
    "@type": "Brand",
    "name": "Holger Kampffmeyer DJ Dienstleistungen"
  }
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
    {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"},
    {"@type": "ListItem", "position": 3, "name": "LD Maui 28 G3", "item": "https://soundundlicht-stuttgart.de/vermietung/ld-maui-28g3"}
  ]
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
  }))
};
const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "LD Maui 28 G3 Sound-Check Demo",
  "description": "Sound-Check der LD Maui 28 G3 PA Anlage in Aktion - professionelles Säulensystem mit 2060W Peak-Leistung",
  "thumbnailUrl": ["/img/vermietung/djpaket.webp"],
  "contentUrl": "https://www.youtube.com/watch?v=vE5PQ7IUdrg",
  "embedUrl": "https://www.youtube.com/embed/vE5PQ7IUdrg",
  "uploadDate": "2024-03-15T00:00:00+00:00",
  "duration": "PT1M32S",
  "publisher": {
    "@type": "Organization",
    "name": "Sound und Licht Stuttgart - Holger Kampffmeyer",
    "logo": { "@type": "ImageObject", "url": "/img/djhulk_logo.webp" }
  }
};
const specs = {
  "Peak-Leistung": "2060 W",
  "RMS-Leistung": "1030 W",
  "Max. SPL": "127 dB",
  "Frequenzbereich": "37 Hz - 20 kHz",
  "Subwoofer": '12" (305 mm)',
  "Midrange": "12 x 3.5\"",
  "Hochtöner": "2 x 1\"",
  "Dispersion": "120° x 30°",
  "Bluetooth": "5.0 mit AAC",
  "Gewicht": "35.4 kg",
  "Abmessungen Subwoofer": "370 x 527 x 472 mm",
  "Gesamthöhe": "2052 mm"
};
const rentalIncludes = [
  "2x LD Maui 28 G3 Säulensystem",
  "2x Stromkabel",
  "2x XLR Kabel 5m",
  "Transporttaschen"
];
const events = [
  { title: "Hochzeit", description: "Perfekt für die musikalische Untermalung deiner Hochzeitsfeier mit bis zu 150 Gästen. Kraftvoller und klarer Sound für Musik und Durchsagen.", personCount: "bis 150 Personen" },
  { title: "Firmenfeier", description: "Ideal für Betriebsfeiern, Jubiläen und Firmenevents. Professioneller Sound für Reden, Präsentationen und musikalische Untermalung.", personCount: "bis 150 Personen" },
  { title: "Vereinsfeier", description: "Egal ob Sportverein, Musikverein oder sonstige Vereinsfeier - der kraftvolle Sound sorgt für beste Stimmung bei allen Gästen.", personCount: "bis 150 Personen" }
];
---

<ProductLayout 
  product={product}
  pageTitle={pageTitle}
  description="Miete das LD Maui 28 G3 Säulensystem für deine Party, Hochzeit oder Firmenfeier. Die LD Maui 28 G3 ist eine professionelle PA-Anlage mit starkem Bass, druckvollem und glasklarem Sound, mit 2060W, 127 dB Schalldruck, für bis zu 150 Personen."
  image="/img/vermietung/djpaket.webp"
  preloadImage="/img/vermietung/djpaket.webp"
  pagefindType="produkt"
  pagefindMeta={{ price: product.price, image: images[0], category: "Sound", label: "Säulensystem 2x LD Maui 28 G3 (Paar)" }}
  galleryImages={images}
  jsonLd={[productSchema, serviceSchema, breadcrumbSchema, faqSchema, videoSchema]}
  breadcrumbSegments={breadcrumbSegments}
>
  <section slot="hero" class="relative min-h-[60vh] flex items-center overflow-hidden">
    <img src="/img/vermietung/djpaket.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
    <div class="hero-overlay-accent"></div>
    <div class="relative z-10 w-full py-32 px-4">
      <div class="max-w-6xl mx-auto">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
        <div class="flex flex-wrap gap-3 mt-3 mb-2">
            <span class="price-badge">{product.price}</span>
          <span class="plug-badge-inline">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Inkl. Kabel & Einweisung
          </span>
        </div>
        <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4 gradient-text">LD Maui 28 G3</h1>
        <p class="text-[var(--color-text)] text-xl max-w-2xl">
          Professionelles Säulen-PA-System mit kraftvollem Sound für bis zu 150 Personen. <br />
           Die LD Maui 28 G3 bietet mit 2060W und 127 dB Schalldruck einen beeindruckenden druckvollen und glasklaren Klang, einen starken tiefgehenden Bass für Partys, Hochzeiten und Firmenfeiern.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Video</span>
        <h2 class="font-play text-3xl font-bold mt-2">Sound-Check PA Anlage</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Eindruck der LD Maui 28 G3 in Aktion</p>
      </div>
       <div class="aspect-video rounded-xl overflow-hidden bg-[var(--color-bg)]">
        <iframe 
          src="https://www.youtube.com/embed/vE5PQ7IUdrg" 
          title="LD Maui 28 G3 Demo"
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <RentalPricing price={product.price} deposit={200} />
  <TechnicalSpecs specs={specs} />
  <RentalIncludes items={rentalIncludes} />
  <ExampleEvents events={events} />

  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-details bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="faq-icon">
                <Icon name="chevron-right" class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>
</ProductLayout>

