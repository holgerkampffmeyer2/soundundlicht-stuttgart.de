---
import ProductLayout from '../../components/vermietung/ProductLayout.astro';
import Icon from '../../components/Icon.astro';
import PackageContents from '../../components/vermietung/PackageContents.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import Testimonials from '../../components/Testimonials.astro';
import { getCollection } from 'astro:content';
import { getFaqsForPage } from '../../lib/faqUtils';

const products = await getCollection('products');
const product = products.find(i => i.data.slug === 'akku-party-paket')!.data;

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Vermietung", href: "/vermietung" },
  { label: "Akku-Party-Paket – Outdoor" }
];

const pageTitle = "Akku-Party-Paket mieten in Stuttgart | Sound & Licht Stuttgart";

const faqs = await getFaqsForPage('akku-party-paket');

const images = [
  "/img/vermietung/Outdoor-Akku-Set1.webp",
  "/img/vermietung/Outdoor-Akku-Set2.webp",
  "/img/vermietung/Outdoor-Akku-Set3.webp",
  "/img/vermietung/Outdoor-Akku-Set4.webp",
  "/img/vermietung/Outdoor-Akku-Set5.webp",
  "/img/vermietung/LED-Par-Lights-Akku1.webp",
  "/img/vermietung/LED-Par-Lights-Akku2.webp",
  "/img/vermietung/enginestar-akku2.webp",
  "/img/vermietung/enginestar-akku1.webp"
];

const packageItems = [
  { name: "2x JBL Partybox 300/320 (Akkubetrieb)", detailPage: "/vermietung/jbl-partybox-300-320" },
  { name: "2x Akku LED PAR Lichter" },
  { name: "EnginStar R350 Powerstation 350W" },
  { name: "Stairville LED BossFX-2 Pro", detailPage: "/vermietung/led-bossfx-nebelmaschine" },
  { name: "Strom- und Anschlusskabel" }
];

const events = [
  {
    title: "Gartenparty / Outdoor-Party",
    description: "Perfekt für Gartenpartys, Grillfeste und Feiern im Freien ohne Stromanschluss. Die Akkus halten 4-6 Stunden – genug für eine ganze Party.",
    personCount: "50-80 Personen"
  },
  {
    title: "Location ohne Stromanschluss",
    description: "Viele Locations (Vereinsheime, Garagen, Schuppen, Pavillons) haben keinen oder schlechten Stromzugang. Unser Akku-Paket löst dieses Problem.",
    personCount: "50-80 Personen"
  },
  {
    title: "Festival / Camping",
    description: "Ob am Baggersee, auf dem Festival-Campingplatz oder bei einer Wanderparty – das Akku-Paket bringt Sound und Licht dorthin, wo es keinen Strom gibt.",
    personCount: "50-80 Personen"
  }
];

const packageFeatures = [
  "Komplett akkubetrieben – kein Stromanschluss nötig",
  "4-6 Stunden Partylaufzeit je nach Lautstärke",
  "2x JBL Partyboxen mit 18h Akku + Lichteffekten",
  "LED BossFX-2 Pro Lichtanlage (betrieben über Powerstation)",
  "2x Akku LED PAR Lichter für Ambientebeleuchtung",
  "EnginStar Powerstation 350W / 296Wh als Stromversorgung",
  "Outdoor-tauglich – ideal für Garten, Festival, Camping",
  "Schneller Aufbau – in 15 Minuten einsatzbereit",
  "Alle Kabel und Verbindungen inklusive"
];

const siteUrl = "https://soundundlicht-stuttgart.de";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Akku-Party-Paket – Outdoor Vermietung",
  "description": "Miete das Akku-Party-Paket für Outdoor-Partys ohne Stromanschluss. Komplett akkubetrieben – 2x JBL Partyboxen mit eigenem Akku, LED BossFX Licht betrieben über Powerstation, 2x Akku LED PAR Lichter und EnginStar Powerstation.",
  "image": [
    siteUrl + images[0],
    siteUrl + images[1]
  ],
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://soundundlicht-stuttgart.de/vermietung/akku-party-paket",
    "price": product.priceValue.toString(),
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
    {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"},
    {"@type": "ListItem", "position": 3, "name": "Akku-Party-Paket – Outdoor", "item": "https://soundundlicht-stuttgart.de/vermietung/akku-party-paket"}
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<ProductLayout 
  product={product}
  pageTitle={pageTitle}
  description="Miete das Akku-Party-Paket für Outdoor-Partys ohne Stromanschluss. Komplett akkubetrieben mit JBL Partyboxen, LED BossFX Licht und EnginStar Powerstation. 4-6h Laufzeit."
  image="/img/vermietung/Akku-powered-party-hero.webp"
  preloadImage="/img/vermietung/Akku-powered-party-hero.webp"
  pagefindType="produkt"
  pagefindMeta={{ price: product.price, image: images[0], category: "Paket", label: "Akku-Party-Paket – Outdoor" }}
  galleryImages={images}
  jsonLd={[serviceSchema, breadcrumbSchema, faqSchema]}
  breadcrumbSegments={breadcrumbSegments}
>
    <!-- Hero -->
    <section slot="hero" class="relative min-h-[60vh] flex items-center overflow-hidden">
      <img src="/img/vermietung/Akku-powered-party-hero.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-overlay-accent"></div>
      <div class="relative z-10 w-full py-32 px-4">
        <div class="max-w-6xl mx-auto">
          <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
          <div class="flex flex-wrap gap-3 mt-3 mb-2">
            <span class="price-badge">{product.price}</span>
            <span class="plug-badge-inline">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Inkl. Kabel & Einweisung
            </span>
          </div>
          <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4 gradient-text">Akku-Party-Paket – Outdoor</h1>
          <p class="text-[var(--color-text)] text-xl max-w-2xl">
            Das Komplettpaket für Partys an Orten ohne Stromanschluss. Enthält 2x JBL Partyboxen (Akkubetrieb, 18h Laufzeit), 
            eine LED BossFX-2 Pro Lichtanlage, 2x Akku LED PAR Lichter und die EnginStar R350 Powerstation zur Stromversorgung 
            der Lichttechnik.<br />
            Alles komplett akkubetrieben – ideal für Gartenpartys, Festivals, Camping und Locations ohne Stromzugang. 
            Inklusive aller Kabel und Verbindungen. Perfekt für 50-80 Personen.
          </p>
        </div>
      </div>
    </section>

  <!-- Package Highlights -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Highlights</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Die Besonderheiten des Akku-Party-Pakets</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {packageFeatures.map((feature) => (
          <div class="bg-[var(--color-bg)] p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-secondary)] transition-all duration-300">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-secondary)] text-2xl">✓</span>
              <p class="text-[var(--color-text)]">{feature}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 2. Preis & Kaution -->
  <RentalPricing price={product.price} deposit={300} />

  <!-- 3. Enthalten im Paket -->
  <PackageContents title="Enthalten im Akku-Party-Paket" items={packageItems} />

  <!-- 4. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- FAQ -->
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-details bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="faq-icon">
                <Icon name="chevron-right" class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />
</ProductLayout>

