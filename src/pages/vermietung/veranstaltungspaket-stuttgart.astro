---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import PackageContents from '../../components/vermietung/PackageContents.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import Testimonials from '../../components/Testimonials.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { getFaqsForPage } from '../../lib/faqUtils';
import CartButton from '../../components/CartButton.astro';
import StickyCTA from '../../components/StickyCTA.astro';

const products = await getCollection('products');
const product = products.find(i => i.data.slug === 'veranstaltungspaket-stuttgart')!.data;

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Vermietung", href: "/vermietung" },
  { label: "Veranstaltungspaket" }
];

const pageTitle = "Veranstaltungspaket | Sound und Licht Stuttgart - Holger Kampffmeyer";

const faqs = await getFaqsForPage('veranstaltungspaket-stuttgart');

const images = [
  "/img/vermietung/ldmaui3.webp",
  "/img/vermietung/LDMAUI28G3_1_kl.webp",
  "/img/vermietung/ldmaui2.webp",
  "/img/vermietung/ld-3.webp",
  "/img/vermietung/IMG_4594.webp",
  "/img/vermietung/yamaha_mg6_kl.webp",
  "/img/vermietung/eurolite-kls-laser-bar.webp",
  "/img/vermietung/eurolite-kls-laser-bar2.webp",
  "/img/vermietung/stairville-af-150-fog-machine.webp",
  "/img/vermietung/stairville-af-150-fog-machine-1.webp",
  "/img/vermietung/IMG_9114.webp",
  "/img/vermietung/IMG_7142.webp",
  "/img/vermietung/IMG_9130.webp",
  "/img/vermietung/IMG_9131.webp"
];

const packageItems = [
  { name: "2x LD Maui 28 G3 Säulensystem", detailPage: "/vermietung/ld-maui-28g3" },
  { name: "Yamaha MG6 6-Kanal Mischpult" },
  { name: "Eurolite KLS Laser Bar", detailPage: "/vermietung/kls-laser-bar" },
  { name: "Stairville AF-150 Nebelmaschine", detailPage: "/vermietung/led-bossfx-nebelmaschine" },
  { name: "2x LED Spot Moving Head" },
  { name: "Mikrofon inkl. Kabel" },
  { name: "4x LED PAR Strahler" },
  { name: "Stromkabel und alle notwendigen Anschlusskabel mit dabei" }
];

const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "Veranstaltungspaket Stuttgart Sound-Check",
  "description": "Sound-Check der LD Maui 28 G3 PA Anlage - Teil des Veranstaltungspakets Stuttgart mit professionellem Säulensystem und 2060W Peak-Leistung",
  "thumbnailUrl": ["/img/vermietung/ldmaui3.webp"],
  "contentUrl": "https://www.youtube.com/watch?v=vE5PQ7IUdrg",
  "embedUrl": "https://www.youtube.com/embed/vE5PQ7IUdrg",
  "uploadDate": "2024-03-15T00:00:00+00:00",
  "duration": "PT1M32S",
  "publisher": {
    "@type": "Organization",
    "name": "Sound und Licht Stuttgart - Holger Kampffmeyer",
    "logo": {
      "@type": "ImageObject",
      "url": "/img/djhulk_logo.webp"
    }
  }
};

const events = [
  {
    title: "Hochzeit",
    description: "Das ideale Paket für Hochzeitsfeiern bis 150 Gäste. Professioneller Sound für Musik und Reden, kombiniert mit einer beeindruckenden Lichtshow.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Firmenfeier",
    description: "Perfekt für Betriebsfeiern, Jubiläen und Firmenevents. Leistungsstarke Anlage für klare Durchsagen und musikalische Untermalung.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Vereinsfeier",
    description: "Egal ob Sportverein, Musikverein oder sonstige Vereinsfeier - das Veranstaltungspaket liefert professionellen Sound und Licht für jede Größe.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Gartenfest",
    description: "Auch für größere Gartenfeste mit bis zu 150 Gästen geeignet. Wetterfeste Aufstellung und kraftvoller Sound auch im Außenbereich.",
    personCount: "bis 150 Personen"
  }
];

const packageFeatures = [
  "Leistungsstarkes Komplettpaket für mittlere Feiern",
  "LD Maui 28 G3 - professionelles Säulensystem mit erstklassigem Sound",
  "Yamaha 6-Kanal Mischpult für flexible Audio-Steuerung",
  "KLS Laser Bar mit spektakulären Licht- und Lasereffekten (kein Laserschutzbeauftragter nötig)",
  "Nebelmaschine für atmosphärische Lichtwirkung",
  "2 Moving Heads für dynamische Lichtshows",
  "Mikrofon für Durchsagen und Ansprachen",
  "4 LED PAR Strahler für atmosphärische Ambientebeleuchtung",
  "Alle notwendigen Strom- und Anschlusskabel inklusive - einfacher Aufbau",
  "Passt in einen Kombi oder Kleinwagen mit umgeklappter Rückbank"
];

const siteUrl = "https://soundundlicht-stuttgart.de";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungspaket Stuttgart Vermietung",
  "description": "Miete das Veranstaltungspaket für dein Event in Stuttgart. Komplette Eventtechnik mit LD Maui Soundanlage, Licht, Nebel und Moving Heads für bis zu 150 Personen.",
  "image": [
    siteUrl + images[0],
    siteUrl + images[1]
  ],
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://soundundlicht-stuttgart.de/#business"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://soundundlicht-stuttgart.de/vermietung/veranstaltungspaket-stuttgart",
    "price": product.priceValue.toString(),
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
    {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"},
    {"@type": "ListItem", "position": 3, "name": "Veranstaltungspaket Stuttgart", "item": "https://soundundlicht-stuttgart.de/vermietung/veranstaltungspaket-stuttgart"}
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout 
  title={pageTitle}
  description="Miete das Veranstaltungspaket für dein Event in Stuttgart. Komplette Eventtechnik mit LD Maui Soundanlage, Licht, Nebel und Moving Heads für bis zu 150 Personen."
  image="/img/vermietung/veranstaltungspaket.webp"
  preloadImage="/img/vermietung/veranstaltungspaket.webp"
  pagefindType="produkt"
  pagefindMeta={{ price: product.price, image: images[0], category: "Paket", label: "Veranstaltungspaket" }}
  jsonLd={[serviceSchema, breadcrumbSchema, faqSchema, videoSchema]}
>
  <Navbar currentPage="/vermietung" />

  <Breadcrumb segments={breadcrumbSegments} />

    <!-- Hero -->
    <section class="relative min-h-[60vh] flex items-center overflow-hidden">
      <img src="/img/vermietung/veranstaltungspaket.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-overlay-accent"></div>
      <div class="relative z-10 w-full py-32 px-4">
        <div class="max-w-6xl mx-auto">
          <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
          <div class="flex flex-wrap gap-3 mt-3 mb-2">
            <span class="price-badge">{product.price}</span>
            <span class="plug-badge-inline">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Inkl. Kabel & Einweisung
            </span>
          </div>
          <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4 gradient-text">Veranstaltungspaket Stuttgart</h1>
          <p class="text-[var(--color-text)] text-xl max-w-2xl">
            Miete unser professionelles Veranstaltungspaket für dein Event in Stuttgart und Umgebung. Das Set enthält das leistungsstarke LD Maui 28 G3 Säulensystem mit erstklassigem Sound, ein Yamaha 6-Kanal Mischpult für flexible Audio-Steuerung, eine Eurolite KLS Laser Bar für spektakuläre Licht- und Lasereffekte, eine Stairville AF-150 Nebelmaschine für atmosphärische Wirkung sowie Moving Heads, Mikrofon und LED PAR Strahler für komplette Beschallung und Beleuchtung.<br />
            Alles inklusive notwendiger Strom- und Anschlusskabel für einfachen Aufbau. Perfekt für Hochzeiten, Firmenfeiern, Vereinsfeste und Gartenpartys bis zu 150 Personen.
          </p>
        </div>
      </div>
    </section>

  <!-- Package Highlights -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Highlights</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Die Besonderheiten des Veranstaltungspakets</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {packageFeatures.map((feature) => (
          <div class="bg-[var(--color-bg)] p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-secondary)] transition-all duration-300">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-secondary)] text-2xl">✓</span>
              <p class="text-[var(--color-text)]">{feature}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="Veranstaltungspaket" />

  <!-- Demo Video -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Video</span>
        <h2 class="font-play text-3xl font-bold mt-2">Sound-Check PA-Anlage</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Eindruck der LD Maui 28 G3 in Aktion</p>
      </div>
      <div class="aspect-video rounded-xl overflow-hidden bg-black">
        <iframe 
          src="https://www.youtube.com/embed/vE5PQ7IUdrg" 
          title="LD Maui 28 G3 Demo"
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 2. Preis & Kaution -->
  <RentalPricing price={product.price} deposit={400} />

  <!-- 3. Enthalten im Paket -->
  <PackageContents title="Enthalten im Veranstaltungspaket" items={packageItems} />

  <!-- 4. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- FAQ -->
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-details bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="faq-icon">
                <Icon name="chevron-right" class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-2">Interessiert an diesem Paket?</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Stell uns eine Anfrage für das Veranstaltungspaket oder lass dich beraten.
      </p>
      <button id="request-now-veranstaltungspaket-stuttgart" class="btn-primary max-w-sm mx-auto mb-6">
        <span class="flex items-center justify-center gap-2">
          <Icon name="cart" class="w-5 h-5" />
          Jetzt anfragen
        </span>
      </button>
      <div class="flex flex-wrap gap-3 justify-center items-center mb-4">
        <CartButton product={product} class="btn-secondary" />
      </div>
      <a href="/vermietung" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] text-sm inline-flex items-center gap-1 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Zurück zur Übersicht
      </a>
    </div>
    <script>
      import { addItem } from '../../lib/cartStore';
      document.getElementById('request-now-veranstaltungspaket-stuttgart')?.addEventListener('click', function() {
        addItem('veranstaltungspaket-stuttgart');
        document.dispatchEvent(new CustomEvent('toggle-cart'));
      });
    </script>
  </section>

  <Testimonials />

  <StickyCTA href="/vermietung#kontakt" productSlug={product.slug} />

  <Footer />
</Layout>

<style>
  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
