---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import PackageContents from '../../components/vermietung/PackageContents.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import Testimonials from '../../components/Testimonials.astro';
import ChevronRightIcon from '../../components/icons/ChevronRightIcon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getFaqsForPage } from '../../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Vermietung", href: "/vermietung" },
  { label: "Partypaket" }
];

const pageTitle = "Partypaket Stuttgart - Partytechnik Miete | DJ Hulk";

const faqs = getFaqsForPage('partypaket-stuttgart');

const images = [
  "/img/vermietung/partypaket1.webp",
  "/img/vermietung/jbl-set1.webp",
  "/img/vermietung/jblpartyboxen.webp",
  "/img/vermietung/jblpartyboxen2.webp",
  "/img/vermietung/eurolite-kls-laser-bar.webp",
  "/img/vermietung/eurolite-kls-laser-bar2.webp",
  "/img/vermietung/stairville-af-150-fog-machine.webp",
  "/img/vermietung/stairville-af-150-fog-machine-1.webp",
  "/img/vermietung/mikrofon.webp",
  "/img/vermietung/36-parlight.webp"
];

const packageItems = [
  { name: "2x JBL Partybox 300", detailPage: "/vermietung/jbl-partybox-300-320" },
  { name: "Eurolite KLS Laser Bar", detailPage: "/vermietung/kls-laser-bar" },
  { name: "Stairville AF-150 Nebelmaschine", detailPage: "/vermietung/led-bossfx-nebelmaschine" },
  { name: "Mikrofon inkl. Kabel" },
  { name: "4x LED PAR Strahler" },
  { name: "Stromkabel und Anschlusskabel" }
];

const events = [
  {
    title: "Geburtstagsfeier",
    description: "Das perfekte Paket für Geburtstagsfeiern bis 50 Gäste. Kraftvoller Sound und stimmungsvolle Beleuchtung sorgen für partytaugliche Stimmung.",
    personCount: "bis 50 Personen"
  },
  {
    title: "Hausparty",
    description: "Ob im Wohnzimmer oder im Garten - das Partypaket liefert den Sound und das Licht für eine unvergessliche Feier.",
    personCount: "bis 50 Personen"
  },
  {
    title: "Kleinere Veranstaltungen",
    description: "Ideal für kleinere Firmenfeiern, After-Work-Partys oder private Feiern mit begrenztem Platzangebot.",
    personCount: "bis 50 Personen"
  }
];

const packageFeatures = [
  "Kompaktes Komplettpaket für kleinere Feiern",
  "Einfacher Aufbau - innerhalb von 30-45 Minuten einsatzbereit",
  "JBL Partyboxen mit dynamischen Lichteffekten",
  "Laser-BAR für spektakuläre Lichtshow ohne Laserschutzbeauftragten",
  "Nebelmaschine für atmosphärische Lichtwirkung",
  "Inklusive Mikrofon für Durchsagen und Ansprachen",
  "4 LED PAR Strahler für stimmungsvolle Ambientebeleuchtung",
  "Strom- und Anschlusskabel inklusive",
  "Passt in einen Kombi oder Kleinwagen mit umgeklappter Rückbank"
];

const siteUrl = "https://soundundlicht-stuttgart.de";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Partypaket Stuttgart Vermietung",
  "description": "Miete das Partypaket für deine Party in Stuttgart und Umgebung. Komplette Partytechnik mit JBL Partyboxen, Licht, Nebel und Mikrofon für bis zu 50 Personen.",
  "image": [
    siteUrl + images[0],
    siteUrl + images[1]
  ],
  "provider": {
    "@type": "Person",
    "name": "Holger Kampffmeyer",
    "telephone": "+49-171-1467491",
    "url": "https://soundundlicht-stuttgart.de"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://soundundlicht-stuttgart.de/vermietung/partypaket-stuttgart",
    "price": "160",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
    {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"},
    {"@type": "ListItem", "position": 3, "name": "Partypaket Stuttgart", "item": "https://soundundlicht-stuttgart.de/vermietung/partypaket-stuttgart"}
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout 
  title={pageTitle}
  description="Miete das Partypaket für deine Party in Stuttgart und Umgebung. Komplette Partytechnik mit JBL Partyboxen, Licht, Nebel und Mikrofon für bis zu 50 Personen."
  image="/img/vermietung/partypaket1.webp"
  jsonLd={[serviceSchema, breadcrumbSchema, faqSchema, {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Partypaket Stuttgart Demo",
    "description": "Demo des Partypakets Stuttgart - JBL Partyboxen, LED Licht und Nebelmaschine",
    "thumbnailUrl": ["/img/vermietung/partypaket1.webp"],
    "contentUrl": "https://www.youtube.com/watch?v=Ivch0DqKkW0",
    "embedUrl": "https://www.youtube.com/embed/Ivch0DqKkW0",
    "uploadDate": "2024-01-20T00:00:00+00:00",
    "duration": "PT1M30S",
    "publisher": {
      "@type": "Organization",
      "name": "DJ Hulk",
      "logo": {
        "@type": "ImageObject",
        "url": "/img/djhulk_logo.webp"
      }
    }
  }]}
>
  <Navbar currentPage="/vermietung" />

  <Breadcrumb segments={breadcrumbSegments} />

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">Partypaket Stuttgart</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Das Party-Starterpaket für kleinere Feiern bis ca. 50 Personen. 
        Komplette Technik mit Sound, Licht, Nebel und Mikrofon aus einer Hand.
      </p>
    </div>
  </section>

  <!-- Package Highlights -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Highlights</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Die Besonderheiten des Partypakets</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {packageFeatures.map((feature) => (
          <div class="bg-[var(--color-bg)] p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-secondary)] transition-all duration-300">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-secondary)] text-2xl">✓</span>
              <p class="text-[var(--color-text)]">{feature}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="Partypaket" />

  <!-- Demo Video -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Video</span>
        <h2 class="font-play text-3xl font-bold mt-2">Sound-Check</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Eindruck der JBL Partyboxen 300 und 320 in Aktion</p>
      </div>
      <div class="aspect-video rounded-xl overflow-hidden bg-black">
        <iframe 
          src="https://www.youtube.com/embed/Ivch0DqKkW0" 
          title="JBL Partybox Demo"
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 160€" deposit={200} />

  <!-- 3. Enthalten im Paket -->
  <PackageContents title="Enthalten im Partypaket" items={packageItems} />

  <!-- 4. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- FAQ -->
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer group">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="w-6 h-6 bg-orange-500/20 rounded flex items-center justify-center text-orange-500 group-open:rotate-90 transition-transform">
                <ChevronRightIcon class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Interessiert an diesem Paket?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Stell uns eine Anfrage für das Partypaket oder lass dich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
    </div>
  </section>

  <Testimonials />

  <Footer />
</Layout>

<style>
  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
