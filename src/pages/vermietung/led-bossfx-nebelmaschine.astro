---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import TechnicalSpecs from '../../components/vermietung/TechnicalSpecs.astro';
import RentalIncludes from '../../components/vermietung/RentalIncludes.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import IncludedInPackages from '../../components/vermietung/IncludedInPackages.astro';
import ChevronRightIcon from '../../components/icons/ChevronRightIcon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getFaqsForPage } from '../../lib/faqUtils';

const breadcrumbSegments = [
  { label: "Startseite", href: "/" },
  { label: "Vermietung", href: "/vermietung" },
  { label: "LED BossFX & Nebelmaschine" }
];

const pageTitle = "LED BossFX-2 Pro & Nebelmaschine - Vermietung | DJ Hulk";

const faqs = getFaqsForPage('led-bossfx-nebelmaschine');

const includedInPackages = [
  { name: "Partypaket", url: "/vermietung/partypaket-stuttgart" },
  { name: "Veranstaltungspaket", url: "/vermietung/veranstaltungspaket-stuttgart" },
  { name: "DJ-Paket Fildern", url: "/vermietung/djpaket-fildern" }
];

const images = [
  "/img/vermietung/LED-BossFX2-Pro-Nebel-AI.webp",
  "/img/vermietung/stairville-led-bossfx-2-pro-bundle.webp",
  "/img/vermietung/stairville-led-bossfx-2-pro-2.webp",
  "/img/vermietung/stairville-led-bossfx-2-pro-3.webp",
  "/img/vermietung/stairville-led-bossfx-2-pro-4.webp",
  "/img/vermietung/stairville-af-150-fog-machine-2.webp",
  "/img/vermietung/stairville-af-150-fog-machine-1.webp"
];

const siteUrl = "https://soundundlicht-stuttgart.de";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "LED BossFX-2 Pro & Nebelmaschine Vermietung",
  "description": "Miete die LED Party-Lichtanlage BossFX-2 Pro mit AF-150 Nebelmaschine. Sound-zu-Licht Modus und DMX-Steuerung für deine Party.",
  "image": [
    siteUrl + images[0],
    siteUrl + images[1]
  ],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Sound & Licht Stuttgart - Holger Kampffmeyer",
    "telephone": "+49-171-1467491",
    "url": "https://soundundlicht-stuttgart.de"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://soundundlicht-stuttgart.de/vermietung/led-bossfx-nebelmaschine",
    "price": "60",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soundundlicht-stuttgart.de/"},
    {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://soundundlicht-stuttgart.de/vermietung"},
    {"@type": "ListItem", "position": 3, "name": "LED BossFX-2 Pro & Nebelmaschine", "item": "https://soundundlicht-stuttgart.de/vermietung/led-bossfx-nebelmaschine"}
  ]
};

const specsPartylicht = {
  "Modell": "Stairville LED BossFX-2 Pro",
  "Effekte": "2 Derbys, 2 LED Flood Panels, 4 Strobe-LEDs",
  "Steuerung": "Sound-zu-Licht, Fernbedienung",
  "Stativ": "inklusive",
  "Besonderheiten": "Weißes UV und Strobe kombiniert"
};

const specsNebelmaschine = {
  "Modell": "Stairville AF-150 DMX",
  "Leistung": "800 W",
  "Ausstoß": "ca. 110 m³/min",
  "Fluid": "1L inklusive",
  "Steuerung": "DMX, Fernbedienung"
};

const rentalIncludes = [
  "1x Stairville LED BossFX-2 Pro Lichtanlage",
  "1x Stairville AF-150 Nebelmaschine",
  "1x Stativ",
  "1x Fernbedienung",
  "1L Nebelfluid"
];

const events = [
  {
    title: "Geburtstagsfeier",
    description: "Die Kombination aus Licht und Nebel sorgt für eine top Party-Atmosphäre. Perfekt für Geburtstagsfeiern und private Feiern.",
    personCount: "bis 100 Personen"
  },
  {
    title: "Hochzeit",
    description: "Verleih deiner Hochzeit das gewisse Extra mit beeindruckender Lichtshow und Nebeleffekten.",
    personCount: "bis 100 Personen"
  },
  {
    title: "Firmenfeier",
    description: "Professionelle Beleuchtung für Firmenfeiern und Events. Die Lichteffekte kommen durch den Nebel besonders gut zur Geltung.",
    personCount: "bis 100 Personen"
  }
];

const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "LED BossFX & Nebelmaschine Demo",
  "description": "Demo der LED BossFX-2 Pro Partylichtanlage mit AF-150 Nebelmaschine in Aktion",
  "thumbnailUrl": ["/img/vermietung/stairville-led-bossfx-2-pro-bundle.webp"],
  "contentUrl": "https://www.youtube.com/watch?v=MzCgO9gkBzQ",
  "embedUrl": "https://www.youtube.com/embed/MzCgO9gkBzQ",
  "uploadDate": "2024-02-10T00:00:00+00:00",
  "duration": "PT45S",
  "publisher": {
    "@type": "Organization",
    "name": "DJ Hulk",
    "logo": {
      "@type": "ImageObject",
      "url": "/img/djhulk_logo.webp"
    }
  }
};
---

<Layout 
  title={pageTitle}
  description="Miete die LED Party-Lichtanlage BossFX-2 Pro mit AF-150 Nebelmaschine. Sound-zu-Licht Modus und DMX-Steuerung für deine Party."
  image="/img/vermietung/stairville-led-bossfx-2-pro-bundle.webp"
  jsonLd={[serviceSchema, breadcrumbSchema, faqSchema, videoSchema]}
>
  <Navbar currentPage="/vermietung" />

  <Breadcrumb segments={breadcrumbSegments} />

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">LED BossFX-2 Pro & Nebelmaschine</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Die Stairville LED BossFX-2 Pro ist eine komplette Party-Lichtanlage für DJs und Events: mit 2 Derby-Beams, 2 hellen Flood-Panels, 4 Strobe-LEDs (Weiß/UV) und schnellem Plug-and-Play-Aufbau inklusive Stativ.
        <br />
         Erhältlich auch als Set mit leistungsstarker 800W Nebelmaschine. Unerlässlich, um die Lichteffekte richtig zur Geltung zu bringen!
      </p>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="LED BossFX-2 Pro & Nebelmaschine" />

  <!-- Demo Video -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Video</span>
        <h2 class="font-play text-3xl font-bold mt-2">Light-Demo</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Eindruck der LED BossFX-2 Pro in Aktion</p>
      </div>
      <div class="aspect-video rounded-xl overflow-hidden bg-black">
        <iframe 
          src="https://www.youtube.com/embed/MzCgO9gkBzQ" 
          title="LED BossFX Demo"
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 60€" deposit={100} />

  <!-- 3a. Technische Spezifikation Partylicht -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Technische Daten</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">LED BossFX-2 Pro</h2>
      </div>
      <TechnicalSpecs specs={specsPartylicht} />
    </div>
  </section>

  <!-- 3b. Technische Spezifikation Nebelmaschine -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">AF-150 Nebelmaschine</h2>
      </div>
      <TechnicalSpecs specs={specsNebelmaschine} />
    </div>
  </section>

   <!-- 4. Lieferumfang -->
   <RentalIncludes items={rentalIncludes} />

   <!-- 5. Beispielanwendungen -->
   <ExampleEvents events={events} />

   <!-- FAQ -->
   <section class="section-padding">
     <div class="max-w-4xl mx-auto px-4">
<h2 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h2>
       <div class="space-y-4">
         {faqs.map((faq) => (
           <details class="bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer group">
             <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
               <span class="w-6 h-6 bg-orange-500/20 rounded flex items-center justify-center text-orange-500 group-open:rotate-90 transition-transform">
                 <ChevronRightIcon class="w-3 h-3" />
               </span>
               {faq.question}
             </summary>
             <p class="text-[var(--color-text-muted)] mt-3 ml-9">
               {faq.answer}
             </p>
           </details>
         ))}
       </div>
     </div>
   </section>

   <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-2">Interessiert an diesem Produkt?</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Stell uns eine Anfrage für die LED BossFX-2 Pro mit Nebelmaschine oder lass dich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
      <IncludedInPackages packages={includedInPackages} />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
