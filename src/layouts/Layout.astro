---
import '../styles/global.css';
import '../styles/fonts.css';
import '../styles/theme-vars.css';
import { localBusinessJsonLd, siteNavigationJsonLd } from '../data/jsonLd';
import { rentalItems } from '../data/rental-catalog';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  jsonLd?: object | object[];
  preloadImage?: string;
  pagefindType?: string;
  pagefindMeta?: Record<string, string>;
}

const {
  title,
  description = "Vermietung von Lautsprechern, Musikanlagen, Partyboxen und Partybeleuchtung für jede Feier im Großraum Stuttgart.",
  image = "/img/header.webp",
  noIndex = false,
  jsonLd,
  preloadImage,
  pagefindType,
  pagefindMeta
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const pagefindBodyWeight = pagefindType === 'produkt' ? '2' : undefined;
const pagefindMerged: Record<string, string> = {};
if (pagefindType) pagefindMerged['type'] = pagefindType;
if (pagefindMeta) Object.assign(pagefindMerged, pagefindMeta);
const pagefindMetaKeys = Object.keys(pagefindMerged);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Holger Kampffmeyer" />
    <meta name="keywords" content="Partytechnik mieten Stuttgart, Verleih Stuttgart, PA-Anlage mieten, Partybox mieten, Lautsprecher mieten, Lichttechnik mieten, Musikanlage mieten, DJ-Equipment mieten, Leinfelden-Echterdingen, Esslingen, Tübingen, Veranstaltungstechnik, Hochzeit, Firmenfeier, Geburtstag" />
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow" } />

    <!-- Theme: set data-theme via ?theme=<name> before paint -->
    <script is:inline>
      (function(){var m=window.location.search.match(/[?&]theme=(electric-night|deep-bass|golden-hour|arctic-frost)(&|$)/);if(m)document.documentElement.setAttribute('data-theme',m[1]);})();
    </script>

    {preloadImage && <link rel="preload" as="image" fetchpriority="high" href={preloadImage} />}
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/josefin-sans-variable.woff2" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content="Sound & Licht Stuttgart" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <title>{title}</title>

    <!-- JSON-LD WebPage with mainEntity -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalURL.href,
      "mainEntity": {
        "@id": "https://soundundlicht-stuttgart.de/#business"
      }
    })} />

    <!-- Schema.org LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />

    <!-- JSON-LD SiteNavigationElement -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteNavigationJsonLd)} />

    {jsonLd && (
      Array.isArray(jsonLd) ? jsonLd : [jsonLd]
    ).map(item => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body class="min-h-screen" data-pagefind-weight={pagefindBodyWeight}>
    <slot />

    <div class="rental-search-fixed">
      <div class="rental-search-wrapper">
        <svg class="rental-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="search" id="pagefind-search-input" data-rental-search placeholder="Technik, Pakete durchsuchen..." aria-label="Technik suchen" />
      </div>
      <div id="pagefind-search-overlay" class="rental-search-overlay" style="display:none"></div>
    </div>

    {pagefindMetaKeys.length > 0 && pagefindMetaKeys.map(key => (
      <div data-pagefind-meta={`${key}:${pagefindMerged[key]}`} hidden></div>
    ))}

    <script id="rental-catalog-data" type="application/json" set:html={JSON.stringify(rentalItems)}></script>

    <script is:inline>
(function() {
  'use strict';

  var DEBOUNCE_MS = 300;
  var MAX_RESULTS = 10;
  var pagefindPromise = null;
  var overlay = document.getElementById('pagefind-search-overlay');
  var input = document.getElementById('pagefind-search-input');
  var debounceTimer = null;
  var selectedIndex = -1;

  if (!input || !overlay) return;

  var wrapper = input.parentElement;
  wrapper.style.position = 'relative';

  function escapeHtml(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  function loadPagefind() {
    if (!pagefindPromise) {
      pagefindPromise = import('/pagefind/pagefind.js').catch(function () {
        pagefindPromise = null;
        return null;
      });
    }
    return pagefindPromise;
  }

  function normalizeUrl(url) {
    return url ? url.replace(/\/$/, '') : url;
  }

  async function doSearch(query) {
    var pf = await loadPagefind();
    if (!pf) return [];
    var search = await pf.search(query);
    if (!search || !search.results) return [];
    var results = await Promise.all(
      search.results.slice(0, MAX_RESULTS).map(function (r) { return r.data(); })
    );
    results.forEach(function (r) { r.url = normalizeUrl(r.url); });
    results.sort(function (a, b) {
      var aP = (a.meta && a.meta.type === 'produkt') ? 0 : 1;
      var bP = (b.meta && b.meta.type === 'produkt') ? 0 : 1;
      return aP - bP;
    });
    return results;
  }

  function cleanPageTitle(t) {
    return (t || '').replace(/\s*[|–—-]\s*Sound\s*(?:und|&)\s*Licht\s*Stuttgart.*$/i, '').trim();
  }

  var rentalCatalog = null;
  try {
    var catScript = document.getElementById('rental-catalog-data');
    if (catScript) rentalCatalog = JSON.parse(catScript.textContent || '[]');
  } catch(e) {}

  function matchCatalogProducts(query) {
    if (!query || !rentalCatalog) return [];
    var q = query.toLowerCase().trim();
    var words = q.split(/\s+/).filter(function(w) { return w.length > 1; });
    var scored = [];
    rentalCatalog.forEach(function(p) {
      var haystack = (p.title + ' ' + p.description + ' ' + (p.features || []).join(' '));
      haystack = haystack.toLowerCase();
      var score = 0;
      words.forEach(function(w) { if (haystack.indexOf(w) !== -1) score++; });
      if (score > 0) scored.push({ item: p, score: score });
    });
    scored.sort(function(a, b) { return b.score - a.score; });
    return scored.map(function(s) { return s.item; });
  }

  function renderProductCard(product, list, query) {
    var el = document.createElement('a');
    el.className = 'rental-search-item';
    el.href = product.detailPage || '/vermietung';
    el.setAttribute('data-index', list.children.length);
    var catClass = 'rental-search-badge badge-' + (product.category || '').toLowerCase();
    var imgHtml = product.image
      ? '<img src="' + escapeHtml(product.image) + '" alt="" loading="lazy" width="48" height="48">'
      : '';
    el.innerHTML = imgHtml +
      '<div class="rental-search-item-text">' +
        '<div class="rental-search-item-title">' + escapeHtml(product.title) + '</div>' +
        '<div class="rental-search-meta">' +
          '<span class="' + catClass + '">' + escapeHtml(product.category || '') + '</span>' +
          '<span class="rental-search-price">' + escapeHtml(product.price || '') + '</span>' +
        '</div>' +
      '</div>';
    el.addEventListener('mousedown', function (e) {
      e.preventDefault();
      window.location.href = el.href;
    });
    list.appendChild(el);
  }

  function renderResults(results, query) {
    if (!overlay) return;
    overlay.innerHTML = '';
    if (results.length === 0) {
      overlay.innerHTML = '<div class="rental-search-empty">Keine Ergebnisse f&uuml;r &quot;' + escapeHtml(query) + '&quot;</div>';
      overlay.style.display = 'block';
      return;
    }
    var list = document.createElement('div');
    var catalogMatchedUrls = {};
    var hasVermietungHit = results.some(function(r) {
      return r.url === '/vermietung' || r.url === '/vermietung/';
    });
    if (hasVermietungHit && rentalCatalog) {
      var matched = matchCatalogProducts(query);
      if (matched.length) {
        matched.forEach(function(p) {
          renderProductCard(p, list, query);
          if (p.detailPage && p.detailPage.indexOf('#') === -1) {
            catalogMatchedUrls[p.detailPage] = true;
          }
        });
      }
    }
    results.forEach(function (item) {
      if (item.url === '/vermietung' || item.url === '/vermietung/') return;
      if (catalogMatchedUrls[item.url]) return;
      var el = document.createElement('a');
      el.className = 'rental-search-item';
      el.href = item.url;
      el.setAttribute('data-index', list.children.length);
      var meta = item.meta || {};
      var isProduct = meta.type === 'produkt';

      if (isProduct) {
        var image = meta.image || '';
        var price = meta.price || '';
        var category = meta.category || '';
        var catClass = 'rental-search-badge badge-' + category.toLowerCase();
        var imgHtml = image ? '<img src="' + escapeHtml(image) + '" alt="" loading="lazy" width="48" height="48">' : '';
        var displayTitle = meta.label || cleanPageTitle(meta.title);
        el.innerHTML = imgHtml +
          '<div class="rental-search-item-text">' +
            '<div class="rental-search-item-title">' + escapeHtml(displayTitle) + '</div>' +
            '<div class="rental-search-meta">' +
              (category ? '<span class="' + catClass + '">' + escapeHtml(category) + '</span>' : '') +
              (price ? '<span class="rental-search-price">' + escapeHtml(price) + '</span>' : '') +
            '</div>' +
          '</div>';
      } else {
        var excerpt = item.excerpt || '';
        el.innerHTML =
          '<div class="rental-search-item-text">' +
            '<div class="rental-search-item-title">' + escapeHtml(cleanPageTitle(meta.title)) + '</div>' +
            (excerpt ? '<div class="rental-search-snippet">' + escapeHtml(excerpt) + '</div>' : '') +
          '</div>';
      }

      el.addEventListener('mousedown', function (e) {
        e.preventDefault();
        window.location.href = item.url;
      });
      list.appendChild(el);
    });
    if (list.children.length === 0) {
      overlay.innerHTML = '<div class="rental-search-empty">Keine Ergebnisse f&uuml;r &quot;' + escapeHtml(query) + '&quot;</div>';
      overlay.style.display = 'block';
      return;
    }
    overlay.appendChild(list);
    overlay.style.display = 'block';
    selectedIndex = -1;
  }

  function showResults(query) {
    doSearch(query).then(function (results) { renderResults(results, query); });
  }

  function onInput() {
    clearTimeout(debounceTimer);
    var val = input.value.trim();
    if (val.length < 2) { overlay.style.display = 'none'; return; }
    debounceTimer = setTimeout(function () { showResults(val); }, DEBOUNCE_MS);
  }

  function onKeydown(e) {
    var items = overlay.querySelectorAll('.rental-search-item');
    if (e.key === 'Escape') { overlay.style.display = 'none'; input.blur(); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); selectedIndex = Math.min(selectedIndex + 1, items.length - 1); updateSelection(items); return; }
    if (e.key === 'ArrowUp') { e.preventDefault(); selectedIndex = Math.max(selectedIndex - 1, 0); updateSelection(items); return; }
    if (e.key === 'Enter' && selectedIndex >= 0 && items[selectedIndex]) { e.preventDefault(); window.location.href = items[selectedIndex].href; return; }
  }

  function updateSelection(items) {
    items.forEach(function (el, i) { el.classList.toggle('rental-search-item-active', i === selectedIndex); });
    if (items[selectedIndex]) items[selectedIndex].scrollIntoView({ block: 'nearest' });
  }

  function onDocumentClick(e) {
    if (overlay.style.display !== 'none') {
      if (!input.contains(e.target) && !overlay.contains(e.target)) overlay.style.display = 'none';
    }
  }

  function onFocus() {
    var val = input.value.trim();
    if (val.length >= 2) showResults(val);
  }

  input.addEventListener('input', onInput);
  input.addEventListener('keydown', onKeydown);
  input.addEventListener('focus', onFocus);
  document.addEventListener('click', onDocumentClick);

  // Scroll animation observer
  document.querySelectorAll('.animate-on-scroll').forEach(function(el) {
    new IntersectionObserver(function(e) {
      e.forEach(function(x) { if (x.isIntersecting) x.target.classList.add('visible'); });
    }, { threshold: 0.1 }).observe(el);
  });
})();
    </script>
  </body>
</html>
