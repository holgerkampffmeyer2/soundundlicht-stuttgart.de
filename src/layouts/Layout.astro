---
import '../styles/global.css';
import '../styles/fonts.css';
import '../styles/theme-vars.css';
import { localBusinessJsonLd, siteNavigationJsonLd } from '../data/jsonLd';
import WishlistDrawer from '../components/WishlistDrawer.astro';
import RentalCatalogData from '../components/RentalCatalogData.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  jsonLd?: object | object[];
  preloadImage?: string;
  pagefindType?: string;
  pagefindMeta?: Record<string, string>;
}

const {
  title,
  description = "Vermietung von Lautsprechern, Musikanlagen, Partyboxen und Partybeleuchtung für jede Feier im Großraum Stuttgart.",
  image = "/img/header.webp",
  noIndex = false,
  jsonLd,
  preloadImage,
  pagefindType,
  pagefindMeta
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const pagefindBodyWeight = pagefindType === 'produkt' ? '2' : undefined;
const pagefindMerged: Record<string, string> = {};
if (pagefindType) pagefindMerged['type'] = pagefindType;
if (pagefindMeta) Object.assign(pagefindMerged, pagefindMeta);
const pagefindMetaKeys = Object.keys(pagefindMerged);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Holger Kampffmeyer" />
    <meta name="keywords" content="Partytechnik mieten Stuttgart, Verleih Stuttgart, PA-Anlage mieten, Partybox mieten, Lautsprecher mieten, Lichttechnik mieten, Musikanlage mieten, DJ-Equipment mieten, Leinfelden-Echterdingen, Esslingen, Tübingen, Veranstaltungstechnik, Hochzeit, Firmenfeier, Geburtstag" />
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow" } />

    <!-- Theme: set data-theme via ?theme=<name> before paint -->
    <script is:inline>
      (function(){var m=window.location.search.match(/[?&]theme=(electric-night|deep-bass|golden-hour|arctic-frost)(&|$)/);if(m)document.documentElement.setAttribute('data-theme',m[1]);})();
    </script>

    {preloadImage && <link rel="preload" as="image" fetchpriority="high" href={preloadImage} />}
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/josefin-sans-variable.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/inter-variable.woff2" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content="Sound & Licht Stuttgart" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <title>{title}</title>

    <!-- JSON-LD WebPage with mainEntity -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalURL.href,
      "mainEntity": {
        "@id": "https://soundundlicht-stuttgart.de/#business"
      }
    })} />

    <!-- Schema.org LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />

    <!-- JSON-LD SiteNavigationElement -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteNavigationJsonLd)} />

    {jsonLd && (
      Array.isArray(jsonLd) ? jsonLd : [jsonLd]
    ).map(item => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  <!-- Fix for invalid mix-blend-mode in Astro view transitions -->
  <style>
    @keyframes astroFadeIn {
      from {
        opacity: 0;
        mix-blend-mode: normal !important
      }
      to {
        opacity: 1;
        mix-blend-mode: normal !important
      }
    }

    @keyframes astroFadeOut {
      from {
        opacity: 1;
        mix-blend-mode: normal !important
      }
      to {
        opacity: 0;
        mix-blend-mode: normal !important
      }
    }
  </style>
  </head>
  <body class="min-h-screen" data-pagefind-weight={pagefindBodyWeight}>
    <slot />

    <div class="rental-search-fixed">
      <div class="rental-search-wrapper">
        <svg class="rental-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="search" id="pagefind-search-input" data-rental-search placeholder="Technik, Pakete durchsuchen..." aria-label="Technik suchen" />
      </div>
      <div id="pagefind-search-overlay" class="rental-search-overlay" style="display:none"></div>
    </div>

<WishlistDrawer />

{pagefindMetaKeys.length > 0 && pagefindMetaKeys.map(key => (
  <div data-pagefind-meta={`${key}:${pagefindMerged[key]}`} hidden></div>
))}

<RentalCatalogData />

<script>
  import '../scripts/search.ts';
</script>
<script>
  import '../scripts/scroll-animations.ts';
</script>

<script>
  import { addItem, getCart } from '../lib/merklisteStore';

  document.addEventListener('add-to-wishlist', (e: CustomEvent<{ slug: string }>) => {
    const slug = e.detail?.slug;
    if (!slug) return;

    addItem(slug);

    document.querySelectorAll(`[data-action="add-to-wishlist"][data-slug="${slug}"], [data-action="add-to-wishlist"][data-product-slug="${slug}"], [data-wishlist-slug="${slug}"]`).forEach(btn => {
      const cart = getCart();
      const inCart = (cart.items || []).some((i: any) => i.slug === slug);

      if (inCart) {
        btn.innerHTML = `
          <span class="grid grid-cols-[auto_1fr] gap-4 items-start text-left">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-base leading-tight">Gemerkt</span>
          </span>`;
        btn.setAttribute('aria-pressed', 'true');
      }
    });

    document.querySelectorAll('.merkliste-badge').forEach(badge => {
      const cart = getCart();
      const totalItems = (cart.items || []).length;
      badge.textContent = String(totalItems);
      badge.classList.toggle('hidden', totalItems === 0);
    });

    document.dispatchEvent(new CustomEvent('merkliste-prefill'));
  });
</script>
</body>
</html>
