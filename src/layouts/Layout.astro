---
import '../styles/global.css';
import '../styles/fonts.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  jsonLd?: object | object[];
  preloadImage?: string;
}

const { 
  title, 
  description = "Vermietung von Lautsprechern, Musikanlagen, Partyboxen und Partybeleuchtung für jede Feier im Großraum Stuttgart.",
  image = "/img/header.webp",
  noIndex = false,
  jsonLd,
  preloadImage
} = Astro.props;

const canonicalPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/').replace(/\/+$/, '') || '/';
const canonicalURL = new URL(canonicalPath, Astro.site);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Holger Kampffmeyer" />
    <meta name="keywords" content="Partytechnik mieten Stuttgart, Verleih Stuttgart, PA-Anlage mieten, Partybox mieten, Lautsprecher mieten, Lichttechnik mieten, Musikanlage mieten, DJ-Equipment mieten, Leinfelden-Echterdingen, Esslingen, Tübingen, Veranstaltungstechnik, Hochzeit, Firmenfeier, Geburtstag" />
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow" } />
    
    <!-- Theme: set data-theme via ?theme=<name> before paint -->
    <script is:inline>
      (function(){var m=window.location.search.match(/[?&]theme=(electric-night|deep-bass|golden-hour|arctic-frost)(&|$)/);if(m)document.documentElement.setAttribute('data-theme',m[1]);})();
    </script>

    <!-- Theme CSS variables for all alt themes -->
    <style>
      html[data-theme="electric-night"] {
        --color-bg: #0a0a0f;
        --color-surface: #1c0a2e;
        --color-surface-hover: #2d1b4e;
        --color-primary: #a855f7;
        --color-primary-hover: #c084fc;
        --color-secondary: #ec4899;
        --color-secondary-hover: #f472b6;
        --color-accent: #22d3ee;
        --color-text: #f8fafc;
        --color-text-muted: #a1a1aa;
        --color-border: #3b0764;
        --font-heading: 'Poppins', sans-serif;
        --font-body: 'Open Sans', sans-serif;
      }
      html[data-theme="deep-bass"] {
        --color-bg: #050510;
        --color-surface: #0a1628;
        --color-surface-hover: #0f1f3a;
        --color-primary: #2563eb;
        --color-primary-hover: #3b82f6;
        --color-secondary: #1e40af;
        --color-secondary-hover: #2563eb;
        --color-accent: #60a5fa;
        --color-text: #f8fafc;
        --color-text-muted: #64748b;
        --color-border: #1e293b;
        --font-heading: 'Inter', sans-serif;
        --font-body: 'Inter', sans-serif;
      }
      html[data-theme="golden-hour"] {
        --color-bg: #0a0a0f;
        --color-surface: #1a1410;
        --color-surface-hover: #2a1e16;
        --color-primary: #f59e0b;
        --color-primary-hover: #fbbf24;
        --color-secondary: #fb923c;
        --color-secondary-hover: #fdba74;
        --color-accent: #eab308;
        --color-text: #fefce8;
        --color-text-muted: #a8a29e;
        --color-border: #292524;
        --font-heading: 'Playfair Display', serif;
        --font-body: 'Inter', sans-serif;
      }
      html[data-theme="arctic-frost"] {
        --color-bg: #080b12;
        --color-surface: #0f172a;
        --color-surface-hover: #1e293b;
        --color-primary: #60a5fa;
        --color-primary-hover: #93bbfd;
        --color-secondary: #a78bfa;
        --color-secondary-hover: #c4b5fd;
        --color-accent: #67e8f9;
        --color-text: #f1f5f9;
        --color-text-muted: #94a3b8;
        --color-border: #1e293b;
        --font-heading: 'DM Sans', sans-serif;
        --font-body: 'DM Sans', sans-serif;
      }
    </style>

    {preloadImage && <link rel="preload" as="image" fetchpriority="high" href={preloadImage} />}
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/josefin-sans-variable.woff2" />

    <!-- Google Fonts (Theme-Fonts: Inter, Playfair Display, DM Sans, Poppins, Open Sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@400;600;700&family=Poppins:wght@400;600;700&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content="Sound & Licht Stuttgart" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />
    
    <title>{title}</title>
    
    <!-- JSON-LD WebPage with mainEntity -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalURL.href,
      "mainEntity": {
        "@type": "LocalBusiness",
        "name": "DJ Hulk - Holger Kampffmeyer"
      }
    })} />

    <!-- Schema.org LocalBusiness -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "DJ Hulk - Holger Kampffmeyer",
        "description": "Verleih von Musikanlagen, Partyboxen, Lichttechnik und Tontechnik im Großraum Stuttgart. Electronic Music DJ für Events, Feiern und Hochzeiten.",
        "url": "https://soundundlicht-stuttgart.de",
        "telephone": "+491711467491",
        "email": "holger.kampffmeyer+dj@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Magellanstraße 4",
          "addressLocality": "Leinfelden-Echterdingen",
          "postalCode": "70771",
          "addressRegion": "Baden-Württemberg",
          "addressCountry": "DE"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "48.6938",
          "longitude": "9.1539"
        },
        "openingHours": "Mo-Su 09:00-20:00",
        "priceRange": "€€",
        "areaServed": {
          "@type": "State",
          "name": "Baden-Württemberg"
        },
        "sameAs": [
          "https://www.facebook.com/holgerkampffmeyerdj",
          "https://www.instagram.com/djhulk_de",
          "https://www.youtube.com/@djhulk_de",
          "https://www.mixcloud.com/holger-kampffmeyer/",
          "https://holger-kampffmeyer.de"
        ]
      }
    </script>



    <!-- JSON-LD SiteNavigationElement as ItemList -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "itemListElement": [
          {
            "@type": "SiteNavigationElement",
            "position": 1,
            "name": "Startseite",
            "url": "https://soundundlicht-stuttgart.de/"
          },
          {
            "@type": "SiteNavigationElement",
            "position": 2,
            "name": "Pakete",
            "url": "https://soundundlicht-stuttgart.de/#pakete"
          },
          {
            "@type": "SiteNavigationElement",
            "position": 3,
            "name": "Miettechnik",
            "url": "https://soundundlicht-stuttgart.de/#services"
          },
          {
            "@type": "SiteNavigationElement",
            "position": 4,
            "name": "FAQ",
            "url": "https://soundundlicht-stuttgart.de/#faq"
          },
          {
            "@type": "SiteNavigationElement",
            "position": 5,
            "name": "Bewertungen",
            "url": "https://soundundlicht-stuttgart.de/#bewertungen"
          }
        ]
      }
    </script>
    {jsonLd && (
      Array.isArray(jsonLd) ? jsonLd : [jsonLd]
    ).map(item => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body class="min-h-screen">
    <slot />
    <script is:inline type="module">
      document.querySelectorAll('.animate-on-scroll').forEach(function(el) {
        new IntersectionObserver(function(e) {
          e.forEach(function(x) { if (x.isIntersecting) x.target.classList.add('visible'); });
        }, { threshold: 0.1 }).observe(el);
      });
    </script>
  </body>
</html>
